{
  "name": "@orch/cf-durable-object-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Durable Object that hosts a persistent Synadia open-agent bridge — stays discoverable via $SRV.INFO.agents across multiple fetch invocations.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "deploy-dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@nats-io/nats-core": "3.4.0",
    "@nats-io/transport-websockets": "3.0.0",
    "@synadia-ai/agent-service": "0.5.2",
    "@synadia-ai/agents": "0.5.2",
    "@synadia-ai/open-agent": "0.0.1",
    "@ai-sdk/openai": "3.0.53",
    "ai": "6.0.165"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250214.0",
    "typescript": "5.6.3",
    "wrangler": "3.114.17"
  }
}
