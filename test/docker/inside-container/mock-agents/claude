#!/usr/bin/env bash
# mock claude binary for orch Docker tests.
#
# Goals:
#   - Print a banner containing "Claude Code" so `orch-spawn --verify`'s
#     banner-match path succeeds.
#   - Read stdin line by line (so `tmux send-keys` from orch-tell lands
#     visibly in the pane).
#   - Exit cleanly on SIGTERM.
#
# MOCK_USE_SHIM=1: launch orch-agent-shim with the claude-code adapter so
# T9/T10/T11 can exercise the Synadia §12 contract against the real shim.
# Without MOCK_USE_SHIM, runs in plain-echo mode — there is no longer a
# legacy hook-firing fallback (the marker / NATS-publish hooks were retired
# in orch#94; the Synadia bus via the shim is the only event path).
#
# Intentionally NOT modeled on real claude-code semantics — this just
# satisfies the orch plumbing contract.
set -uo pipefail

cat <<'BANNER'
╭─── Claude Code v0 (mock test harness) ─────────────────────────╮
│                                                                  │
│  This is a mock used by orch's Docker test bench. It echoes      │
│  each prompt it receives via stdin. With MOCK_USE_SHIM=1 it      │
│  delegates to orch-agent-shim for full Synadia adapter coverage. │
│                                                                  │
│  Sending SIGTERM exits cleanly.                                  │
│                                                                  │
╰──────────────────────────────────────────────────────────────────╯

BANNER

# --- MOCK_USE_SHIM path: delegate to the real shim -------------------------
if [ "${MOCK_USE_SHIM:-0}" = "1" ]; then
    SHIM_BIN="${SHIM_BIN:-orch-agent-shim}"
    if ! command -v "$SHIM_BIN" >/dev/null 2>&1; then
        echo "[mock] MOCK_USE_SHIM=1 but $SHIM_BIN not found on PATH — falling back to plain-echo mode" >&2
    else
        # Resolve the tmux pane we're running in.  orch-spawn sets $TMUX_PANE
        # (or $ORCH_PANE) before exec'ing us; fall back to the first visible
        # pane id if neither is set.
        PANE="${ORCH_PANE:-${TMUX_PANE:-}}"
        if [ -z "$PANE" ]; then
            PANE=$(tmux list-panes -a -F '#{pane_id}' 2>/dev/null | head -1)
        fi
        if [ -z "$PANE" ]; then
            echo "[mock] MOCK_USE_SHIM=1 but could not determine tmux pane — falling back to plain-echo mode" >&2
        else
            # Pass --heartbeat-interval so T11 can run fast (2s cadence).
            HB_INTERVAL="${SHIM_HB_INTERVAL:-30s}"
            exec "$SHIM_BIN" \
                --agent claude-code \
                --pane "$PANE" \
                --interval "$HB_INTERVAL" \
                ${NATS_URL:+--nats "$NATS_URL"}
            # exec replaces the process — code below is unreachable on success.
        fi
    fi
fi

# --- Plain-echo mode (default) ---------------------------------------------
trap 'exit 0' TERM INT

# Print a prompt-style cursor so capture-pane shows we're alive between turns
echo "❯ ready"

while IFS= read -r line; do
    echo "[mock] received: $line"
    echo "❯ ready"
done
