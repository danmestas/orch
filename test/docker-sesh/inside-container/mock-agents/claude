#!/usr/bin/env bash
# mock claude binary for orch Docker tests.
#
# Goals:
#   - Print a banner containing "Claude Code" so `orch-spawn --verify`'s
#     banner-match path succeeds.
#   - Read stdin line by line (so `tmux send-keys` from orch-tell lands
#     visibly in the pane).
#   - Exit cleanly on SIGTERM.
#
# The legacy hook-firing path (orch-stop-marker.sh + orch-nats-publish-*.sh)
# was retired in orch#94 — bus eventing is now handled by orch-agent-shim
# when MOCK_USE_SHIM=1 is set (see test/docker/inside-container/mock-agents/claude
# for the shim-launch path).
#
# Intentionally NOT modeled on real claude-code semantics — this just
# satisfies the orch plumbing contract.
set -uo pipefail

cat <<'BANNER'
╭─── Claude Code v0 (mock test harness) ─────────────────────────╮
│                                                                  │
│  This is a mock used by orch's Docker test bench. It echoes      │
│  each prompt it receives via stdin.                              │
│                                                                  │
│  Sending SIGTERM exits cleanly.                                  │
│                                                                  │
╰──────────────────────────────────────────────────────────────────╯

BANNER

trap 'exit 0' TERM INT

# Print a prompt-style cursor so capture-pane shows we're alive between turns
echo "❯ ready"

while IFS= read -r line; do
    echo "[mock] received: $line"
    echo "❯ ready"
done
