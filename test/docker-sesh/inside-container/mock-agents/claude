#!/usr/bin/env bash
# mock claude binary for orch Docker tests.
#
# Goals:
#   - Print a banner containing "Claude Code" so `orch-spawn --verify`'s
#     banner-match path succeeds.
#   - Read stdin line by line (so `tmux send-keys` from orch-tell lands
#     visibly in the pane).
#   - Append a transcript JSONL line per prompt at the path the
#     claudecode adapter tails — bridges mock prompts into Synadia
#     response chunks (orch#134).
#   - Exit cleanly on SIGTERM.
#
# Transcript path matches claude-code's convention:
#   ~/.claude/projects/<encoded-cwd>/session-mock.jsonl
# where <encoded-cwd> replaces `/` and `.` with `-`.
set -uo pipefail

cat <<'BANNER'
╭─── Claude Code v0 (mock test harness) ─────────────────────────╮
│                                                                  │
│  This is a mock used by orch's Docker test bench. It echoes      │
│  each prompt it receives via stdin and writes a transcript      │
│  JSONL line per prompt for the shim's transcript tailer.        │
│                                                                  │
╰──────────────────────────────────────────────────────────────────╯

BANNER

trap 'exit 0' TERM INT

encoded_cwd=$(printf '%s' "$PWD" | sed 's:[./]:-:g')
transcript_dir="${HOME}/.claude/projects/${encoded_cwd}"
mkdir -p "$transcript_dir"
transcript="${transcript_dir}/session-mock.jsonl"

# json-escape backslashes and double-quotes; bench prompts have no other
# special chars so this is sufficient (and avoids a jq dependency).
json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    printf '%s' "$s"
}

# Print a prompt-style cursor so capture-pane shows we're alive between turns
echo "❯ ready"

while IFS= read -r line; do
    echo "[mock] received: $line"
    echo "❯ ready"
    reply=$(json_escape "[mock-claude] response: $line")
    printf '{"type":"assistant","message":{"content":[{"type":"text","text":"%s"}]}}\n' \
        "$reply" >>"$transcript"
done
