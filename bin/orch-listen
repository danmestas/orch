#!/usr/bin/env bash
# orch-listen — block until a worker pane fires a Stop / Notification event.
#
# Two modes:
#
# 1) ONE-SHOT (default): print one event block to stdout and exit. Caller is
#    expected to re-launch after processing — but humans and agents forget,
#    leaving the operator deaf. Backward-compatible legacy mode.
#
#      Bash(orch-listen, run_in_background=true)   # one notification
#
# 2) STREAM (`--stream`): print one JSON object per event, never exit on
#    event. Designed to be wrapped in a Monitor so each line is a push
#    notification. Survives many events without manual re-arming.
#
#      Monitor(command="orch-listen --stream", persistent=true,
#              description="harness events")
#
# Pick stream mode unless you specifically need the bash-bg one-shot shape.
#
# Usage:
#   orch-listen [timeout_seconds] [--stream] [--exclude-notify]
#                  [--include-observers] [--exclude <pane[,pane,...]>]
#                  [--exclude-self]
#
# By default, both Stop-event (.event) and Notification (.notify) markers wake
# the listener. Pass --exclude-notify to suppress notify markers and wake only
# on Stop events.
#
# DEPRECATED: --include-notify is the prior opt-in flag for the same default
# behavior. It is silently accepted for backward compat but is a no-op; new
# code should drop it. It may be removed in a future release.
#
# --exclude-self filters out events from the calling pane (resolved via
# `tmux display -p '#{pane_id}'`). Useful when the orchestrator is itself a CC
# session that fires Stop hooks on every turn — without filtering, the listener
# wakes on its own events.
#
# Observer panes (shim metadata.role=="observer", e.g., stasi/wait-watch spies)
# are excluded by default. Pass --include-observers to include them. Workers
# (metadata.role=="worker" or absent) are always included. Role is resolved via
# $SRV.INFO.agents; falls back to "worker" when NATS is unavailable or the pane
# has no shim registration.
#
# One-shot stdout (single block on success):
#   EVENT_FILE=<path>
#   <key=value lines from the marker file>
#
# Stream stdout (one JSON object per line, until timeout):
#   {"event_file":"<path>","ts_ns":N,"pane_id":"%X","ext":"event","kv":{...}}
#
# Exit codes:
#   0  event received (one-shot) / clean stream end (no events seen, signal)
#   1  bad usage / fswatch missing
#   2  timeout
set -euo pipefail

command -v fswatch >/dev/null 2>&1 || { echo "fswatch missing — brew install fswatch" >&2; exit 1; }

DIR="${ORCH_STOP_DIR:-$HOME/.cache/orch-stop}"
mkdir -p "$DIR"

TIMEOUT=3600
INCLUDE_NOTIFY=1
INCLUDE_OBSERVERS=0
STREAM=0
declare -A EXCLUDE

while [ $# -gt 0 ]; do
    case "$1" in
        --stream) STREAM=1; shift ;;
        --include-notify) INCLUDE_NOTIFY=1; shift ;;
        --exclude-notify) INCLUDE_NOTIFY=0; shift ;;
        --include-observers) INCLUDE_OBSERVERS=1; shift ;;
        --exclude) IFS=',' read -ra PS <<<"$2"; for p in "${PS[@]}"; do EXCLUDE["$p"]=1; done; shift 2 ;;
        --exclude-self)
            self=${TMUX_PANE:-$(tmux display -p '#{pane_id}' 2>/dev/null || true)}
            [ -n "$self" ] && EXCLUDE["$self"]=1
            shift ;;
        --help|-h) sed -n '2,53p' "$0"; exit 0 ;;
        --*) echo "orch-listen: unknown flag: $1" >&2; exit 1 ;;
        *) TIMEOUT="$1"; shift ;;
    esac
done

# --stream wants jq for JSON emission. Refuse early if missing.
if [ $STREAM -eq 1 ] && ! command -v jq >/dev/null 2>&1; then
    echo "orch-listen: --stream requires jq" >&2; exit 1
fi

# Discovery timeout for $SRV.INFO.agents role lookups (per-pane call).
# Keep short — this is on the hot event path. Falls back to "worker" on
# timeout or when NATS / jq are absent.
_LISTEN_DISC_TIMEOUT="${ORCH_LISTEN_DISCOVERY_TIMEOUT:-0.5s}"

# Cache of already-resolved roles to avoid a NATS round-trip for every
# event from the same pane during a stream session.
declare -A _ROLE_CACHE

is_observer() {
    local pane=$1

    # Return cached result if we already resolved this pane.
    if [ -n "${_ROLE_CACHE[$pane]+_}" ]; then
        [ "${_ROLE_CACHE[$pane]}" = "observer" ]
        return
    fi

    # Without nats or jq we cannot resolve; treat as worker (include).
    if ! command -v nats >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        _ROLE_CACHE[$pane]="worker"
        return 1
    fi

    local raw role
    # shellcheck disable=SC2016  # $SRV.INFO.agents is a NATS system subject (literal $)
    raw=$(nats --server="${NATS_URL:-}" req '$SRV.INFO.agents' '' \
              --replies=0 "--reply-timeout=${_LISTEN_DISC_TIMEOUT}" 2>/dev/null \
          | grep -v '^Received on\|^---\|^[[:space:]]*$' || true)

    if [ -z "$raw" ]; then
        # Bus unreachable or no agents registered — treat as worker.
        _ROLE_CACHE[$pane]="worker"
        return 1
    fi

    role=$(printf '%s\n' "$raw" \
           | jq -r --arg p "$pane" \
               'select(.metadata.pane_id == $p) | .metadata.role // "worker"' \
               2>/dev/null | head -1)
    role="${role:-worker}"
    _ROLE_CACHE[$pane]="$role"
    [ "$role" = "observer" ]
}

# Watched extensions
if [ "$INCLUDE_NOTIFY" = 1 ]; then
    EXTS=(event notify)
else
    EXTS=(event)
fi

# Snapshot existing marker mtimes so we ignore stale events on startup.
declare -A SEEN
for ext in "${EXTS[@]}"; do
    for f in "$DIR"/*."$ext"; do
        [ -e "$f" ] || continue
        SEEN["$f"]=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null)
    done
done

# Watchdog: force fswatch to wake at TIMEOUT so the deadline check runs even
# when the only events seen are skipped (e.g., observer events when default
# excluded). Without this, fswatch -1 blocks forever after a skip-iteration.
WATCHDOG_FILE="$DIR/.orch-listen-watchdog-$$"
( sleep "$TIMEOUT" && touch "$WATCHDOG_FILE" 2>/dev/null ) &
WATCHDOG_PID=$!
cleanup() { kill "$WATCHDOG_PID" 2>/dev/null || true; rm -f "$WATCHDOG_FILE"; }
trap cleanup EXIT

emit_oneshot() {
    local f=$1
    echo "EVENT_FILE=$f"
    cat "$f"
}

emit_stream() {
    local f=$1 pane=$2 ext=$3
    # Build {key:value,...} object from the marker file's "k=v" lines.
    local kv_json
    kv_json=$(awk -F= '
        BEGIN { printf "{" }
        NF>=2 {
            if (n++) printf ","
            k=$1; sub(/^[ \t]+/, "", k); sub(/[ \t]+$/, "", k)
            v=$0; sub(/^[^=]*=/, "", v)
            gsub(/\\/, "\\\\", v); gsub(/"/, "\\\"", v)
            gsub(/\n/, "\\n", v); gsub(/\r/, "\\r", v); gsub(/\t/, "\\t", v)
            printf "\"%s\":\"%s\"", k, v
        }
        END { printf "}" }
    ' "$f" 2>/dev/null || echo "{}")
    # Portable per-event unique int. `date +%s%N` is GNU-only — on older
    # macOS BSD `date` returns the literal "...N" which isn't valid JSON.
    # Pad $RANDOM (0-32767) to 5 digits and concatenate to seconds for a
    # 15-digit monotonic-ish int that satisfies jq --argjson on any POSIX
    # shell.
    local ts_unique
    ts_unique="$(date +%s)$(printf '%05d' "$RANDOM")"
    jq -nc \
        --arg event_file "$f" \
        --arg pane_id   "$pane" \
        --arg ext       "$ext" \
        --argjson ts_ns_emit "$ts_unique" \
        --argjson kv "$kv_json" \
        '{event_file:$event_file, pane_id:$pane_id, ext:$ext, ts_ns_emit:$ts_ns_emit, kv:$kv}'
}

deadline=$(( $(date +%s) + TIMEOUT ))
while :; do
    if [ "$(date +%s)" -ge "$deadline" ]; then
        if [ $STREAM -eq 1 ]; then
            # Stream mode: clean exit on timeout (Monitor stops watching).
            exit 0
        else
            echo "orch-listen: timeout after ${TIMEOUT}s" >&2
            exit 2
        fi
    fi

    # Block until any file in DIR is created/modified.
    fswatch -1 "$DIR" > /dev/null 2>&1 || sleep 1

    # Identify which watched file changed (new or mtime-bumped).
    for ext in "${EXTS[@]}"; do
        for f in "$DIR"/*."$ext"; do
            [ -e "$f" ] || continue
            cur=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null)
            prev="${SEEN[$f]:-0}"
            if [ "$cur" != "$prev" ]; then
                # Filename pattern: <pane_id>.<ext> → strip ext to get pane_id.
                pane_id=$(basename "$f" ".$ext")
                if [ -n "${EXCLUDE[$pane_id]:-}" ]; then
                    SEEN["$f"]=$cur  # mark seen so we don't loop on the same self-event
                    continue
                fi
                if [ "$INCLUDE_OBSERVERS" = 0 ] && is_observer "$pane_id"; then
                    SEEN["$f"]=$cur  # observer fired Stop; default policy is silent
                    continue
                fi
                SEEN["$f"]=$cur
                if [ $STREAM -eq 1 ]; then
                    emit_stream "$f" "$pane_id" "$ext"
                else
                    emit_oneshot "$f"
                    exit 0
                fi
            fi
        done
    done
done
