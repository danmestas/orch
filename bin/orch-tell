#!/usr/bin/env bash
# orch-tell — inject a prompt into a pane running an interactive agent.
#
# Usage:
#   orch-tell <pane_id|alias> <prompt words...>
#   orch-tell <pane_id|alias> -                 # read prompt from stdin
#   orch-tell [--force] <pane_id|alias> <prompt>
#   orch-tell --list                            # list panes + commands
#   orch-tell --collect <pane> <prompt>         # request/reply; stream chunks to stdout
#   orch-tell --legacy-keystrokes <pane> <prompt>  # bypass discovery; use tmux send-keys
#
# Default path (discovery):
#   1. Resolve alias → pane id.
#   2. Query $SRV.INFO.agents filtered by metadata.pane_id == <pane>.
#   3. Publish prompt to endpoints[name=="prompt"].subject (fire-and-forget).
#   On no match: actionable error + exit 1.
#
# --collect: request/reply mode — streams §6.2 response chunk .data to stdout
#   until the §6.5 zero-byte terminator. §9 Nats-Service-Error headers map:
#     400→2  401-403→3  404→4  409→5  429→6  500+→1
#   Use --timeout N (seconds) to override the 30s inactivity window between chunks.
#
# --legacy-keystrokes: skips NATS discovery; falls back to tmux send-keys.
#   Useful for panes that were spawned without a shim.
#
# Env overrides:
#   ORCH_TELL_DISCOVERY_TIMEOUT (default 2s)   — $SRV.INFO.agents reply-timeout
#   ORCH_TELL_INACTIVITY_TIMEOUT (default 30)  — --collect inactivity window (seconds)
#   ORCH_TELL_MAX_WAIT (default 30)            — legacy-keystrokes idle deadline (seconds)
#   ORCH_TELL_IDLE_DELAY (default 0.3)         — legacy-keystrokes poll interval
#   ORCH_TELL_SUBMIT_DELAY (default 0.1)       — legacy-keystrokes Enter delay
#   ORCH_TELL_FORCE_LEGACY (unset)             — when set to 1, skip discovery
#                                                entirely and use tmux send-keys.
#                                                Used by orch-nats-bridge-in and
#                                                orch-subscribe daemons where the
#                                                target is known to be a raw pane
#                                                without a registered shim.
#   NATS_URL                                   — NATS server URL (default per nats CLI)
#
# Auto-fallback: if discovery returns no match for the pane AND the pane exists
# in tmux, orch-tell silently falls back to legacy keystrokes with a stderr
# note. This preserves backward compatibility for callers (orch-subscribe,
# orch-nats-bridge-in, ad-hoc operator use) that target panes spawned before
# Plan 8 or with --no-shim. To force discovery-only behavior, run from a pane
# that has a registered shim or pass --collect (which has no legacy fallback).
#
# Aliases: one per line "name=%pane_id" in ~/.config/orch-aliases.
# Pane ids start with "%" — anything else is looked up as an alias.
#
# Observer-target policy (A1): a worker pane (ORCH_PANE_ID set in env) is
# refused when telling an observer-class target unless --force is passed.
# Observers exist to watch, not to be redirected by workers. Operator panes
# (no ORCH_PANE_ID) are unrestricted.
#
# Idle detection (legacy path): capture-pane twice with a small delay; if the
# screen is unchanged the agent is considered idle. If it never settles within
# ORCH_TELL_MAX_WAIT seconds, exit non-zero.
set -euo pipefail

ALIAS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/orch-aliases"
MAX_WAIT="${ORCH_TELL_MAX_WAIT:-30}"
IDLE_DELAY="${ORCH_TELL_IDLE_DELAY:-0.3}"
# Discovery: how long to wait for $SRV.INFO.agents replies (reply-timeout between replies).
DISCOVERY_TIMEOUT="${ORCH_TELL_DISCOVERY_TIMEOUT:-2s}"
# Collect: inactivity window — how long to wait between chunks before giving up.
INACTIVITY_TIMEOUT="${ORCH_TELL_INACTIVITY_TIMEOUT:-30}"

die() { printf 'orch-tell: %s\n' "$*" >&2; exit 1; }

if [ "${1:-}" = "--list" ]; then
    command -v tmux >/dev/null 2>&1 \
        || die "tmux not found on PATH (required for --list)"
    tmux list-panes -a -F '#{pane_id}  #{session_name}:#{window_index}.#{pane_index}  #{pane_current_command}  #{pane_current_path}'
    exit 0
fi

# Strip flags from anywhere in the arg list so they compose cleanly with the
# positional <pane> <prompt...> shape.
FORCE=0
COLLECT=0
LEGACY=0
TIMEOUT_OVERRIDE=""
ARGS=()
while [ "$#" -gt 0 ]; do
    case $1 in
        --force)              FORCE=1; shift ;;
        --collect)            COLLECT=1; shift ;;
        --legacy-keystrokes)  LEGACY=1; shift ;;
        --timeout)            TIMEOUT_OVERRIDE=$2; shift 2 ;;
        --timeout=*)          TIMEOUT_OVERRIDE=${1#--timeout=}; shift ;;
        *)                    ARGS+=("$1"); shift ;;
    esac
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

[ "$#" -ge 2 ] || die "usage: orch-tell [--force] [--collect] [--legacy-keystrokes] [--timeout N] <pane_id|alias> <prompt> | --list"

[ -n "$TIMEOUT_OVERRIDE" ] && INACTIVITY_TIMEOUT="$TIMEOUT_OVERRIDE"

target=$1; shift
case $target in
    %*) pane=$target ;;
    *)  [ -f "$ALIAS_FILE" ] || die "no alias file at $ALIAS_FILE; pass a pane id like %35"
        pane=$(awk -F= -v k="$target" '$1==k {print $2; exit}' "$ALIAS_FILE")
        [ -n "$pane" ] || die "alias '$target' not found in $ALIAS_FILE"
        ;;
esac

# Worker→observer guard: a worker (ORCH_PANE_ID set) cannot redirect an
# observer-class target unless --force.
#
# Target role is resolved from $SRV.INFO.agents (metadata.role). Falls back
# to "worker" when NATS / jq are absent or the target is not registered —
# unregistered panes are not subject to the guard (no role to enforce).
if [ -n "${ORCH_PANE_ID:-}" ] && [ $FORCE -eq 0 ] \
   && command -v nats >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    # shellcheck disable=SC2016  # $SRV.INFO.agents is a NATS system subject (literal $)
    _guard_raw=$(nats --server="${NATS_URL:-}" req '$SRV.INFO.agents' '' \
                     --replies=0 "--reply-timeout=${DISCOVERY_TIMEOUT}" 2>/dev/null \
                 | grep -v '^Received on\|^---\|^[[:space:]]*$' || true)
    if [ -n "$_guard_raw" ]; then
        target_role=$(printf '%s\n' "$_guard_raw" \
                      | jq -r --arg p "$pane" \
                          'select(.metadata.pane_id == $p) | .metadata.role // "worker"' \
                          2>/dev/null | head -1)
        if [ "$target_role" = "observer" ]; then
            die "refusing to tell observer pane $pane (sender is worker $ORCH_PANE_ID); pass --force to override"
        fi
    fi
fi

if [ "$1" = "-" ]; then
    prompt=$(cat)
else
    prompt="$*"
fi

# ── §9 error code → exit code table ──────────────────────────────────────────
# One table; not a switch buried in logic. Called after detecting error headers.
_exit_for_error_code() {
    local code=$1
    if   [ "$code" -eq 400 ];                         then return 2
    elif [ "$code" -ge 401 ] && [ "$code" -le 403 ]; then return 3
    elif [ "$code" -eq 404 ];                         then return 4
    elif [ "$code" -eq 409 ];                         then return 5
    elif [ "$code" -eq 429 ];                         then return 6
    elif [ "$code" -ge 500 ];                         then return 1
    else                                                   return 1
    fi
}

# ── Discovery: resolve pane → prompt subject via $SRV.INFO.agents ────────────
# Prints the prompt subject to stdout on success.
# Returns 0 on match, non-zero on no-match / tooling-missing / bus-unreachable.
# Caller decides whether to die or fall back to legacy based on context.
# Assertion: exactly one agent matches; warn-and-pick-first on multiple.
_discover_prompt_subject() {
    local pane_id=$1

    # Tooling missing → caller falls back to legacy (no shim is registered
    # in environments without the nats CLI anyway).
    command -v nats >/dev/null 2>&1 || return 10
    command -v jq   >/dev/null 2>&1 || return 11

    # Collect all $SRV.INFO.agents replies.
    # --replies=0 means collect all until reply-timeout fires between replies.
    # The nats CLI emits each reply body preceded by a "Received on ..." header
    # line. We strip those and blank lines so only JSON bodies remain.
    # NATS_URL — if unset, nats CLI uses its own default (nats://127.0.0.1:4222
    # or NATS_URL env). Passing --server="" is harmless to the CLI, so the same
    # form works whether or not we have a URL.
    local raw=""
    # shellcheck disable=SC2016  # $SRV.INFO.agents is a NATS system subject (literal $)
    raw=$(nats --server="${NATS_URL:-}" req '$SRV.INFO.agents' '' \
              --replies=0 "--reply-timeout=${DISCOVERY_TIMEOUT}" 2>/dev/null \
          | grep -v '^Received on\|^---\|^[[:space:]]*$' || true)

    # Empty $raw = no agents replied (bus unreachable, no agents registered,
    # or all replies stripped as headers). Treat as no-match; caller decides.
    [ -z "$raw" ] && return 1

    # Filter: entries where metadata.pane_id matches; extract prompt subject.
    # Each line of $raw is one JSON object from one agent.
    local matched=""
    matched=$(printf '%s\n' "$raw" \
              | jq -r --arg p "$pane_id" \
                  'select(.metadata.pane_id == $p)
                   | .endpoints[]
                   | select(.name == "prompt")
                   | .subject' 2>/dev/null || true)

    local match_count=0
    [ -n "$matched" ] && match_count=$(printf '%s\n' "$matched" | grep -c .)

    [ "$match_count" -eq 0 ] && return 1

    if [ "$match_count" -gt 1 ]; then
        printf 'orch-tell: warning: %d agents matched pane_id %s (expected 1); using first\n' \
               "$match_count" "$pane_id" >&2
    fi

    printf '%s\n' "$matched" | head -1
    return 0
}

# ── Collect mode: request/reply with chunk streaming ─────────────────────────
# Publishes prompt via NATS request; streams §6.2 response chunk .data to stdout
# AS EACH CHUNK ARRIVES (no buffering). §9 error headers (and the §9.1 JSON
# body if present) surface on stderr; exit code from the _exit_for_error_code
# table above.
#
# Streaming model: `nats req --replies=0 --reply-timeout=Ns` writes each
# reply's headers + body to stdout, then exits when inactivity-timeout fires.
# We pipe directly into a `while read` so each response chunk reaches stdout
# the moment the nats CLI flushes it. Ctrl-C surfaces a partial response.
#
# Termination: we do NOT detect the §6.5 zero-byte terminator explicitly
# (the nats CLI does not surface the empty-body terminator as a parseable
# signal). Instead we rely on EOF from the nats process — `--replies=0`
# exits when reply-timeout fires after the last message. The shim's
# terminator-then-quiet pattern triggers that exit naturally.
_collect_chunks() {
    local subject=$1 prompt_text=$2
    command -v nats >/dev/null 2>&1 \
        || die "nats CLI not found on PATH"

    local in_error=0
    local err_code=""
    local err_msg=""
    local exit_code=0

    # Pipe nats directly into the parser — each chunk emits as it arrives.
    # The trailing `|| true` on the nats invocation is intentional: nats
    # exits non-zero when reply-timeout fires with no replies, which is the
    # normal end-of-stream signal once the shim has sent its terminator.
    #
    # NATS_URL — see _discover_prompt_subject for the empty-string rationale.
    #
    # Process substitution (< <(...)) keeps the while loop in the current
    # shell so err_code / err_msg / in_error / exit_code remain readable
    # after the loop ends. (A plain `nats | while` puts the loop in a
    # subshell and the state would be lost.)
    while IFS= read -r line || [ -n "$line" ]; do
        # §9 error headers — emitted by nats CLI on the "Received on" line
        # or as a separate header line, depending on CLI version.
        if printf '%s' "$line" | grep -q 'Nats-Service-Error-Code:'; then
            err_code=$(printf '%s' "$line" \
                       | grep -oE 'Nats-Service-Error-Code:[[:space:]]*[0-9]+' \
                       | grep -oE '[0-9]+$')
            in_error=1
            continue
        fi
        if printf '%s' "$line" | grep -q 'Nats-Service-Error:'; then
            err_msg=$(printf '%s' "$line" \
                      | sed 's/.*Nats-Service-Error:[[:space:]]*//' \
                      | sed 's/[[:space:]]*$//')
            continue
        fi
        # Skip the "Received on" navigation header
        if printf '%s' "$line" | grep -q '^Received on'; then
            continue
        fi
        # Skip "---" separator
        if [ "$line" = "---" ]; then
            continue
        fi
        # Empty line: either separator between messages, or terminator body
        # (we can't tell which from the nats CLI). If we're in an error
        # window, flush the error and exit. Otherwise just keep going —
        # EOF from the nats process is what actually ends the stream.
        if [ -z "$line" ]; then
            if [ "$in_error" -eq 1 ]; then
                # §9.1: body may carry {"error":..., "message":..., "retry_after_s":...}.
                # We've already captured the header string; if a JSON body
                # follows, it will be the next non-blank line — but parsing
                # it requires lookahead. We surface header info now; §9.1
                # body parsing for the next-line JSON happens below in the
                # JSON-body branch when in_error is still set.
                printf 'orch-tell: agent error %s: %s\n' "$err_code" "$err_msg" >&2
                _exit_for_error_code "$err_code"
                exit_code=$?
                # Drain rest of input quickly — but allow §9.1 body parse
                # on the very next non-blank line if it's JSON.
                in_error=2
                continue
            fi
            continue
        fi
        # JSON body — parse and emit response chunks, or extract §9.1
        # error metadata if we just saw an error header.
        local chunk_type=""
        chunk_type=$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null || true)

        # §9.1 JSON body: {"error":"...","message":"...","retry_after_s":N}.
        # Surface if we're in the error-flushed state and the line parses
        # as a JSON object with a "message" or "retry_after_s" key.
        if [ "$in_error" -eq 2 ]; then
            local body_msg body_retry
            body_msg=$(printf '%s' "$line" | jq -r '.message // empty' 2>/dev/null || true)
            body_retry=$(printf '%s' "$line" | jq -r '.retry_after_s // empty' 2>/dev/null || true)
            if [ -n "$body_msg" ]; then
                printf 'orch-tell: agent error detail: %s\n' "$body_msg" >&2
            fi
            if [ -n "$body_retry" ]; then
                printf 'orch-tell: retry after %ss\n' "$body_retry" >&2
            fi
            in_error=0   # body consumed; don't re-parse subsequent lines
            continue
        fi

        case "$chunk_type" in
            response)
                # Stream the response data to stdout immediately. Use printf
                # with no trailing newline — the shim is authoritative on
                # whether response text contains its own newlines.
                printf '%s' "$line" | jq -r '.data // empty' 2>/dev/null || true
                ;;
            status|thinking|tool_use|query)
                # §6.6: unknown / non-response chunk types are silently
                # ignored. ack (status), thinking, tool_use, query are all
                # structural — operators see the model's actual answer via
                # `response` chunks only.
                ;;
            *)
                # §6.6: unknown chunk types are silently dropped. Forward
                # compatibility: future Synadia versions may add new types.
                ;;
        esac
    done < <(nats --server="${NATS_URL:-}" req "$subject" "$prompt_text" \
                  --replies=0 "--reply-timeout=${INACTIVITY_TIMEOUT}s" 2>/dev/null \
             || true)

    return "$exit_code"
}

# ── Send-log helper ───────────────────────────────────────────────────────────
_write_send_log() {
    # Append to send-log so a parent that returns from a session restart can
    # distinguish prompts the orchestrator sent (here) from prompts the user typed.
    local send_log="${ORCH_SEND_LOG:-$HOME/.cache/orch-send.log}"
    if command -v jq >/dev/null 2>&1; then
        local preview
        preview=$(printf '%s' "$prompt" | head -c 200)
        jq -nc \
            --argjson ts_ns "$(date +%s%N)" \
            --arg pane "$pane" \
            --arg sender "${ORCH_PANE_ID:-orchestrator-${PPID:-?}}" \
            --arg prompt_preview "$preview" \
            --arg prompt_len "${#prompt}" \
            '{ts_ns:$ts_ns, pane:$pane, sender:$sender, prompt_preview:$prompt_preview, prompt_len:($prompt_len|tonumber)}' \
            >> "$send_log" 2>/dev/null || true
    fi
}

# ── Legacy path: tmux send-keys ───────────────────────────────────────────────
_send_via_tmux() {
    command -v tmux >/dev/null 2>&1 \
        || die "tmux not found on PATH (required for --legacy-keystrokes)"

    tmux list-panes -a -F '#{pane_id}' | grep -qx "$pane" \
        || die "pane $pane does not exist"

    local deadline
    deadline=$(( $(date +%s) + MAX_WAIT ))
    local prev=""
    local prev_set=0
    while :; do
        local cur
        cur=$(tmux capture-pane -t "$pane" -p)
        if [ $prev_set -eq 1 ] && [ "$prev" = "$cur" ]; then
            break
        fi
        [ "$(date +%s)" -gt "$deadline" ] \
            && die "pane $pane never went idle within ${MAX_WAIT}s"
        prev=$cur
        prev_set=1
        sleep "$IDLE_DELAY"
    done

    # Inject as literal keystrokes (-l): each char is a typed key, no bracketed-paste
    # wrapping. Then a separate Enter that's interpreted as the special key.
    # A brief sleep is necessary — without it, the Enter often arrives before the
    # TUI has finished consuming the literal stream and the submit is dropped.
    # 50ms is empirically enough; 100ms is safer for slow machines.
    tmux send-keys -t "$pane" -l "$prompt"
    sleep "${ORCH_TELL_SUBMIT_DELAY:-0.1}"
    tmux send-keys -t "$pane" Enter

    _write_send_log
}

# ── Main dispatch ─────────────────────────────────────────────────────────────
# Explicit legacy: --legacy-keystrokes flag OR ORCH_TELL_FORCE_LEGACY=1.
if [ "$LEGACY" -eq 1 ] || [ "${ORCH_TELL_FORCE_LEGACY:-0}" = "1" ]; then
    _send_via_tmux
    exit 0
fi

# Discovery path (default). _discover_prompt_subject returns:
#   0      → printed subject; use NATS
#   1      → no match (no agents replied OR no pane_id match)
#   10/11  → nats / jq tool missing
# On no-match we auto-fallback to legacy IFF the pane exists in tmux; this
# preserves backward compat for orch-subscribe / orch-nats-bridge-in callers
# targeting raw panes (no shim). --collect has no legacy fallback (legacy
# can't return response chunks), so it hard-errors on no-match.
prompt_subject=""
discovery_rc=0
prompt_subject=$(_discover_prompt_subject "$pane") || discovery_rc=$?

if [ "$discovery_rc" -ne 0 ]; then
    # Discovery failed. Decide: hard-error (--collect or no tmux pane) vs
    # silent legacy fallback (pane exists in tmux).
    if [ "$COLLECT" -eq 1 ]; then
        die "pane $pane not registered on the bus (run orch-spawn after Plan 8); --collect requires a shim"
    fi
    if command -v tmux >/dev/null 2>&1 \
       && tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qx "$pane"; then
        printf 'orch-tell: %s not on the bus; falling back to tmux send-keys\n' "$pane" >&2
        _send_via_tmux
        exit 0
    fi
    die "pane $pane not registered on the bus and not present in tmux (run orch-spawn after Plan 8, or use --legacy-keystrokes)"
fi

if [ "$COLLECT" -eq 1 ]; then
    _collect_chunks "$prompt_subject" "$prompt"
else
    # Fire-and-forget: publish to the prompt subject; no reply collection.
    # NATS_URL — see _discover_prompt_subject for the empty-string rationale.
    command -v nats >/dev/null 2>&1 \
        || die "nats CLI not found on PATH"
    nats --server="${NATS_URL:-}" pub "$prompt_subject" "$prompt" 2>/dev/null \
        || die "failed to publish to $prompt_subject"
    _write_send_log
fi
