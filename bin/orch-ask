#!/usr/bin/env bash
# orch-ask — send a prompt to an agent, collect and return response chunks.
#
# This is a thin wrapper around `orch-tell --collect`. It delegates discovery,
# NATS publish, and chunk streaming to orch-tell.
#
# Usage:
#   orch-ask <pane_id|alias> <prompt words...>
#   orch-ask <pane_id|alias> -                      # prompt from stdin
#   orch-ask <pane_id|alias> --timeout N <prompt...> # inactivity timeout (s)
#
# Stdout: concatenated response chunk content from the agent.
# Stderr: status lines unless --quiet.
#
# Exit codes:
#   0  prompt sent and response collected
#   1  bad usage / pane missing / agent error (5xx)
#   2  agent error 400
#   3  agent error 401-403
#   4  agent error 404
#   5  agent error 409
#   6  agent error 429
set -euo pipefail

ALIAS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/orch-aliases"
TIMEOUT=30
QUIET=0

die() { printf 'orch-ask: %s\n' "$*" >&2; exit 1; }

[ "$#" -ge 2 ] || die "usage: orch-ask <pane_id|alias> <prompt> [--timeout N] [--quiet]"

target=$1; shift

# Parse flags — flags can come anywhere after the target.
prompt_args=()
while [ "$#" -gt 0 ]; do
    case $1 in
        --timeout)  TIMEOUT=$2; shift 2 ;;
        --quiet)    QUIET=1; shift ;;
        *)          prompt_args+=("$1"); shift ;;
    esac
done
set -- "${prompt_args[@]}"
[ "$#" -ge 1 ] || die "no prompt provided"

case $target in
    %*) pane=$target ;;
    *)  [ -f "$ALIAS_FILE" ] || die "no alias file at $ALIAS_FILE; pass a pane id like %35"
        pane=$(awk -F= -v k="$target" '$1==k {print $2; exit}' "$ALIAS_FILE")
        [ -n "$pane" ] || die "alias '$target' not found in $ALIAS_FILE"
        ;;
esac

if [ "$1" = "-" ]; then
    prompt=$(cat)
else
    prompt="$*"
fi

[ "$QUIET" = 1 ] || printf 'orch-ask: sending to %s via NATS\n' "$pane" >&2
exec orch-tell --collect --timeout "$TIMEOUT" "$pane" "$prompt"
