#!/usr/bin/env bash
# orch-claim-operator — DEPRECATED. No-op stub.
#
# Operator-pane identity is now established by setting ORCH_ROLE=operator in
# the operator's shell before starting the session, which causes orch-agent-shim
# to register the pane with metadata.role=="operator" on $SRV.INFO.agents.
# Discovery consumers filter by that field; no separate claim file is needed.
#
# To establish operator identity:
#   export ORCH_ROLE=operator   # in your operator shell's profile or .env
#
# ~/.cache/orch-operator.json is no longer written or read.
#
# This stub accepts (and ignores) all prior arguments so operator configs that
# call orch-claim-operator explicitly do not break. It exits 0.
#
# Usage (deprecated):
#   orch-claim-operator [--quiet] [--pane <pane_id>]
echo "orch-claim-operator: deprecated — set ORCH_ROLE=operator in your shell so orch-agent-shim registers the operator role on \$SRV.INFO.agents; this call is a no-op" >&2
exit 0
