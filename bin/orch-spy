#!/usr/bin/env bash
# orch-spy — spawn a stasi/wait-watch observer pane on a target session,
# auto-build the standard brief envelope, send it to the observer.
#
# Codifies the audit-this-session pattern that recurs in transcripts:
#   1. orch-spawn claude --outfit stasi --cut wait-watch  (A1: auto role=observer)
#   2. construct brief with target jsonl + harness state pointers
#   3. orch-tell <new-pane> "$BRIEF"
#
# Usage:
#   orch-spy <target> <mission words...>
#   orch-spy <target> --mission-file <path>
#   orch-spy <target> -                            # mission from stdin
#
# Target:
#   operator        the operator pane from ~/.cache/orch-operator.json
#                   (run orch-claim-operator first)
#   %<pane_id>      the named pane — checked against operator-claim and
#                   the worker registry; transcript JSONL resolved from
#                   whichever matches
#
# Flags:
#   --headed        spawn in current tmux window (default: --headless)
#   --quiet         suppress stderr; on success stdout still carries pane id
#   --mission-file <path>   read mission text from file (overrides positional)
#
# Output contract: stdout is exactly one line — the new spy's pane id.
# Diagnostics on stderr. --quiet silences both.
#
# Observer role: spy is auto-tagged role=observer by orch-spawn (A1), so
# orch-listen default-excludes it. No --exclude needed in the operator's
# listener.
set -euo pipefail

usage() {
    sed -n '2,30p' "$0" >&2
}

QUIET=0
HEADLESS=1
MISSION_FILE=""
TARGET=""
MISSION=""
DRY_RUN_BRIEF=0

# Parse: first positional = target; subsequent positionals = mission text;
# flags can appear anywhere.
TARGET_SET=0
while [ $# -gt 0 ]; do
    case "$1" in
        --quiet) QUIET=1; exec 2>/dev/null; shift ;;
        --headless) HEADLESS=1; shift ;;
        --headed) HEADLESS=0; shift ;;
        --mission-file) MISSION_FILE=${2:-}; shift 2 ;;
        --dry-run-brief) DRY_RUN_BRIEF=1; shift ;;
        --help|-h) usage; exit 0 ;;
        --*) echo "orch-spy: unknown flag: $1" >&2; exit 1 ;;
        *)
            if [ $TARGET_SET -eq 0 ]; then
                TARGET=$1; TARGET_SET=1
            else
                if [ -z "$MISSION" ]; then MISSION=$1; else MISSION="$MISSION $1"; fi
            fi
            shift ;;
    esac
done

[ $TARGET_SET -eq 1 ] || { echo "orch-spy: target required (use 'operator' or %pane_id)" >&2; usage; exit 1; }

# Mission resolution: --mission-file > stdin (single dash) > positional words
if [ -n "$MISSION_FILE" ]; then
    [ -f "$MISSION_FILE" ] || { echo "orch-spy: mission file not found: $MISSION_FILE" >&2; exit 1; }
    MISSION=$(cat "$MISSION_FILE")
elif [ "$MISSION" = "-" ]; then
    MISSION=$(cat)
fi
[ -n "$MISSION" ] || { echo "orch-spy: mission text required (positional, --mission-file, or -)" >&2; exit 1; }

command -v jq            >/dev/null 2>&1 || { echo "orch-spy: jq required" >&2; exit 1; }
command -v orch-spawn >/dev/null 2>&1 || { echo "orch-spy: orch-spawn not on PATH" >&2; exit 1; }
command -v orch-tell  >/dev/null 2>&1 || { echo "orch-spy: orch-tell not on PATH" >&2; exit 1; }

# orch-spy hardcodes `claude --outfit stasi --cut wait-watch`, which requires
# `suit` on PATH and an outfit pack that ships the `stasi` outfit. Skip the
# whole spawn if the dependencies are missing — the suit-prepare error mid-
# spawn is otherwise opaque. (Pre-check can be skipped via ORCH_SPY_SKIP_PRECHECK=1
# for tests / non-default outfit packs that handle the stasi name differently.)
if [ "${ORCH_SPY_SKIP_PRECHECK:-0}" != "1" ]; then
    command -v suit >/dev/null 2>&1 || {
        echo "orch-spy: suit not on PATH — install @agent-ops/suit and an outfit pack containing the 'stasi' outfit (see README 'Optional outfit support')" >&2
        exit 1
    }
fi

OPERATOR_CACHE="${ORCH_OPERATOR_CACHE:-$HOME/.cache/orch-operator.json}"
REG_DIR="${ORCH_REGISTRY_DIR:-$HOME/.cache/orch-registry}"
PROJECTS_DIR="${ORCH_PROJECTS_DIR:-$HOME/.claude/projects}"
SEND_LOG="${ORCH_SEND_LOG:-$HOME/.cache/orch-send.log}"
STOP_DIR="${ORCH_STOP_DIR:-$HOME/.cache/orch-stop}"

# --- Resolve target → pane / transcript / cwd ---
TARGET_PANE=""
TARGET_JSONL=""
TARGET_CWD=""
TARGET_KIND=""

resolve_via_claim() {
    local pane=$1
    [ -f "$OPERATOR_CACHE" ] || return 1
    local claim_pane
    claim_pane=$(jq -r '.pane_id // empty' "$OPERATOR_CACHE" 2>/dev/null || true)
    [ -n "$claim_pane" ] || return 1
    [ "$claim_pane" = "$pane" ] || return 1
    TARGET_PANE=$claim_pane
    TARGET_JSONL=$(jq -r '.transcript_jsonl // empty' "$OPERATOR_CACHE")
    TARGET_CWD=$(jq -r '.cwd // empty' "$OPERATOR_CACHE")
    TARGET_KIND=operator
    [ -f "$TARGET_JSONL" ]
}

resolve_via_registry() {
    local pane=$1
    local reg="$REG_DIR/$pane.json"
    [ -f "$reg" ] || return 1
    TARGET_PANE=$pane
    TARGET_CWD=$(jq -r '.cwd // empty' "$reg")
    [ -n "$TARGET_CWD" ] || return 1

    local resolved encoded session_dir best mt cur f
    resolved=$(cd "$TARGET_CWD" 2>/dev/null && pwd -P) || resolved=$TARGET_CWD
    encoded=$(printf '%s' "$resolved" | sed 's|/|-|g; s|_|-|g')
    session_dir="$PROJECTS_DIR/$encoded"
    [ -d "$session_dir" ] || return 1

    best=""; mt=0
    for f in "$session_dir"/*.jsonl; do
        [ -e "$f" ] || continue
        # GNU stat first (Linux); BSD stat fallback (macOS). The reverse fails on Linux
        # because `stat -f` there means --file-system and "succeeds" with non-numeric output.
        cur=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo 0)
        if [ "$cur" -gt "$mt" ]; then mt=$cur; best=$f; fi
    done
    [ -n "$best" ] || return 1
    TARGET_JSONL=$best
    TARGET_KIND=$(jq -r '.role // "worker"' "$reg" 2>/dev/null || echo worker)
    return 0
}

case "$TARGET" in
    operator|op)
        [ -f "$OPERATOR_CACHE" ] || { echo "orch-spy: no operator-claim record at $OPERATOR_CACHE — run orch-claim-operator first" >&2; exit 1; }
        TARGET_PANE=$(jq -r '.pane_id // empty' "$OPERATOR_CACHE")
        TARGET_JSONL=$(jq -r '.transcript_jsonl // empty' "$OPERATOR_CACHE")
        TARGET_CWD=$(jq -r '.cwd // empty' "$OPERATOR_CACHE")
        TARGET_KIND=operator
        [ -n "$TARGET_PANE" ] && [ -f "$TARGET_JSONL" ] || {
            echo "orch-spy: operator-claim record incomplete or transcript missing" >&2; exit 1; }
        ;;
    %[0-9]*)
        if resolve_via_claim "$TARGET"; then
            :
        elif resolve_via_registry "$TARGET"; then
            :
        else
            echo "orch-spy: $TARGET not in operator-claim ($OPERATOR_CACHE) or registry ($REG_DIR)" >&2
            exit 1
        fi
        ;;
    *)
        echo "orch-spy: target must be 'operator' or %pane_id (got: $TARGET)" >&2
        exit 1 ;;
esac

# --- Spawn the spy (claude + stasi/wait-watch; A1 auto-tags observer) ---
# When --dry-run-brief, skip the spawn and use a placeholder for spy_pane_id.
SPY_PANE="<unspawned>"
if [ $DRY_RUN_BRIEF -eq 0 ]; then
    SPAWN_FLAGS=(claude --outfit stasi --cut wait-watch --no-fleet)
    [ $HEADLESS -eq 1 ] && SPAWN_FLAGS+=(--headless)
    # Run the spy in the target's project so its CLAUDE.md is in scope.
    SPAWN_FLAGS+=(--cwd "$TARGET_CWD")
    if ! SPY_PANE=$(orch-spawn "${SPAWN_FLAGS[@]}" 2>&1); then
        echo "orch-spy: orch-spawn failed: $SPY_PANE" >&2
        exit 1
    fi
    [[ "$SPY_PANE" =~ ^%[0-9]+$ ]] || {
        echo "orch-spy: orch-spawn returned non-pane: $SPY_PANE" >&2; exit 1; }
fi

# --- Build the standard brief envelope ---
BRIEF=$(cat <<EOT
You are a stasi/wait-watch observer spawned via orch-spy.

You are role=observer in the harness registry. The operator's
\`orch-listen\` default-excludes you, so your Stop events do not wake the
operator's listener. Workers cannot tell you (worker→observer is refused
unless --force). You report to the operator via \`orch-tell\`; you do
not redirect the target.

== Mission ==
$MISSION

== Target ==
target_kind:             $TARGET_KIND
target_pane_id:          $TARGET_PANE
target_transcript_jsonl: $TARGET_JSONL
target_cwd:              $TARGET_CWD

== Harness state files (read-only, useful for cross-checks) ==
operator_claim:          $OPERATOR_CACHE
send_log:                $SEND_LOG
event_log_dir:           $STOP_DIR
registry_dir:            $REG_DIR

== Your pane ==
spy_pane_id:             $SPY_PANE

== Reporting back ==
Tail the target transcript JSONL with a Monitor for line-by-line push.
When you observe something the operator should act on, push via
\`orch-tell <operator-pane> "<finding>"\` (look up operator-claim if
target_kind != operator). Do not auto-redirect anything.

Begin.
EOT
)

# --- Dry-run: print the brief and exit ---
if [ $DRY_RUN_BRIEF -eq 1 ]; then
    printf '%s\n' "$BRIEF"
    exit 0
fi

# --- Send the brief to the spy ---
if ! orch-tell "$SPY_PANE" "$BRIEF" >/dev/null; then
    echo "orch-spy: orch-tell to $SPY_PANE failed (spy spawned but unbriefed)" >&2
    exit 1
fi

echo "$SPY_PANE"
