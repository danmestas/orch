#!/usr/bin/env bash
# orch — top-level subcommand dispatcher.
#
# Issue #189 friction points 1 + 3: this is a lazy-build shim around the
# Go binary at cmd/orch/. Built-in Go subcommands (tell / ask / peek /
# spy / migrate-aliases) are handled in-process; unknown subcommands are
# forwarded to a sibling `orch-<sub>` binary on PATH (preserves the
# legacy dispatch model for orch up / orch down / orch spawn / etc.).
#
# Same lazy-build pattern as bin/orch-workflow.
set -euo pipefail

# Locate the package root. Walk up from this script's location until we
# find a go.mod file.
script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
pkg_root="$script_dir"
while [ ! -f "$pkg_root/go.mod" ]; do
    parent=$(dirname "$pkg_root")
    if [ "$parent" = "$pkg_root" ]; then
        echo "orch: cannot find go.mod above $script_dir" >&2
        exit 1
    fi
    pkg_root="$parent"
done

src_dir="$pkg_root/cmd/orch"
build_dir="$pkg_root/.bin"
built="$build_dir/orch"

needs_build=0
if [ ! -x "$built" ]; then
    needs_build=1
else
    # Rebuild if any .go file under cmd/orch, internal/registry, or
    # internal/synadia is newer than the cached binary.
    if find "$src_dir" "$pkg_root/internal/registry" "$pkg_root/internal/synadia" \
        -name '*.go' -newer "$built" -print -quit 2>/dev/null | grep -q .; then
        needs_build=1
    fi
fi

if [ "$needs_build" -eq 1 ]; then
    if ! command -v go >/dev/null 2>&1; then
        echo "orch: 'go' not on PATH; cannot build $src_dir" >&2
        exit 1
    fi
    mkdir -p "$build_dir"
    (cd "$pkg_root" && go build -o "$built" ./cmd/orch) \
        || { echo "orch: build failed" >&2; exit 1; }
fi

exec "$built" "$@"
