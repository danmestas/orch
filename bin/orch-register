#!/usr/bin/env bash
# orch-register — DEPRECATED. No-op stub.
#
# Registration is now handled automatically by orch-agent-shim, which
# publishes each pane's metadata on $SRV.INFO.agents at spawn time.
# ~/.cache/orch-registry/ is no longer written or read.
#
# This stub accepts (and ignores) all prior arguments so operator configs
# that call orch-register explicitly do not break. It exits 0.
#
# Usage (deprecated):
#   orch-register <pane_id> <agent> <cwd> [session_id] [--role <worker|observer>]
echo "orch-register: deprecated — registration is now handled by orch-agent-shim via \$SRV.INFO.agents; this call is a no-op" >&2
exit 0
