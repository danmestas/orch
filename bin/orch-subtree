#!/usr/bin/env bash
# orch-subtree — Phase A entrypoint for Proposal 0006's subtree topology YAML.
#
# Thin shim that lazy-builds the Go binary in cmd/orch-subtree on first
# run (or when the source changes) and execs it. Same pattern as
# bin/orch-workflow.
#
# Phase A subcommands wired: validate, diff, list.
# Phase B subcommands (apply, status, destroy, watch) return exit 3 with
# a "Phase B" message until the NATS-backed SeshResolver / WorkerSpawner
# / StateSeeder wiring lands.
set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
pkg_root="$script_dir"
while [ ! -f "$pkg_root/go.mod" ]; do
    parent=$(dirname "$pkg_root")
    if [ "$parent" = "$pkg_root" ]; then
        echo "orch-subtree: cannot find go.mod above $script_dir" >&2
        exit 1
    fi
    pkg_root="$parent"
done

src_dir="$pkg_root/cmd/orch-subtree"
build_dir="$pkg_root/.bin"
built="$build_dir/orch-subtree"

needs_build=0
if [ ! -x "$built" ]; then
    needs_build=1
else
    if find "$src_dir" "$pkg_root/internal/subtree" "$pkg_root/internal/spawnspec" -name '*.go' -newer "$built" -print -quit 2>/dev/null | grep -q .; then
        needs_build=1
    fi
fi

if [ "$needs_build" -eq 1 ]; then
    if ! command -v go >/dev/null 2>&1; then
        echo "orch-subtree: 'go' not on PATH; cannot build $src_dir" >&2
        exit 1
    fi
    mkdir -p "$build_dir"
    (cd "$pkg_root" && go build -o "$built" ./cmd/orch-subtree) \
        || { echo "orch-subtree: build failed" >&2; exit 1; }
fi

exec "$built" "$@"
