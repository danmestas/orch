#!/usr/bin/env bash
# orch-spawn — dispatcher: parses args, selects executor, delegates spawn.
#
# Usage:
#   orch-spawn <agent> [--cwd <path>] [--sesh-session <label>] [--project <name>]
#                         [--headless] [--no-fleet]
#                         [--quiet] [--role <worker|observer>]
#                         [--position <right|left|above|below>] [--verify]
#                         [--outfit <name>] [--cut <name>] [--accessory <name>]...
#                         [--no-shim] [--executor <tmux|wasm>]
#
# Environment variables:
#   ORCH_SESH_BIN          — absolute path to the `sesh` binary (default: first
#                            `sesh` on PATH). Must be absolute; orch-spawn `cd`s
#                            during resolution, so a relative path can break
#                            silently. Resolved early — error surfaces before
#                            any pane is spawned.
#   ORCH_PROJECTS_ROOT     — fallback root for `--project <name>` lookups when
#                            zoxide miss (default: $HOME/projects).
#   ORCH_VERIFY_TIMEOUT    — readiness poll budget for --verify (default: 60s).
#   ORCH_HEADLESS_SESSION  — name of the detached headless tmux session
#                            (default: orch-headless).
#
# --sesh-session <label> sets the worker's cwd to the fossil checkout
# provisioned by `sesh worktree <label>` — the worker-side leg of the
# fossil-as-trunk swarm workflow (sesh issue #64). orch-spawn shells out
# to `sesh worker-cwd <label>` and uses the printed path as the cwd, so
# the worker lands in <project>/.sesh/checkouts/<label>/ with a live
# fossil checkout ready for fossil commit / fossil update. Mutually
# exclusive with --cwd; pass one or the other, not both.
#
# Executor selection (--executor, default: tmux):
#   tmux  — spawns a tmux pane on the local machine (default). Delegates to
#           executors/tmux/spawn.sh.
#   wasm  — Cloudflare Worker executor. Delegates to executors/wasm/cf-worker/.
#           (Requires wrangler configuration; see executors/wasm/cf-worker/README.md.)
#
# orch-agent-shim is launched by default alongside every spawned pane,
# registering it as a Synadia Agent Protocol v0.3 agent on the sesh hub
# (or $NATS_URL). The shim publishes heartbeats and accepts prompts on
# agents.prompt.cc.<owner>.pct<pane>. Pass --no-shim to disable (useful
# for diagnostics or when orch-agent-shim has no adapter for the target
# harness). The shim is silently skipped if `orch-agent-shim` isn't on
# PATH (warning to stderr, spawn proceeds — keeps install graceful for
# shell-only orchs). Harnesses without a loaded adapter (codex/pi/gemini
# until Plans 11-13) spawn with the shim disabled and a warning; the legacy
# marker-hook fallback was retired in #94 (Synadia is the only path).
#
# --position controls where the new pane is split off the current pane in headed
# mode. Default `right` preserves prior behavior (tmux split-window -h). Mapping:
# right=`-h`, left=`-h -b`, above=`-v -b`, below=`-v`. Ignored in --headless.
#
# --verify polls the new pane after the split for either of two readiness
# signals: (1) pane_current_command becomes anything other than a known
# shell (zsh|bash|sh|fish|dash|ksh) — agents like claude rename their
# process title once launched; or (2) the pane's visible buffer contains a
# per-agent banner string. The second signal absorbs cold-start variance
# when an agent's REPL is interactive before the title rename catches up
# (heavy outfits with many MCP servers / hooks routinely cross the title
# threshold late). The pane dying still counts as a failure. Default
# budget is 60s, overridable via ORCH_VERIFY_TIMEOUT. On success, emits
# one stderr line "orch-spawn: agent ready in pane %X". On failure, emits
# "orch-spawn: agent failed to start in %X (pane died|timeout)" and exits
# non-zero — useful for catching the silent-shell-pane failure mode where
# the agent CLI never actually launches.
#
# Examples:
#   orch-spawn claude --project gonvex
#   orch-spawn pi --cwd ~/projects/bones
#   orch-spawn codex --project dagnats --headless
#   orch-spawn claude --project bones --outfit engineer --cut focused
#   orch-spawn claude --outfit stasi --cut wait-watch       # auto role=observer
#   orch-spawn claude --role observer --outfit engineer     # explicit override
#
# Role: panes are tagged role=worker by default; role=observer when the outfit
# or cut indicates a meta/spy class (stasi outfit, wait-watch cut, spy-on-* cut)
# OR when --role is passed. Subscribers on the Synadia bus can filter on the
# shim's metadata.role field; explicit --role wins over auto-detection.
#
# Default: spawns in the orchestrator's tmux window (headed).
# With --headless, spawns in the detached `orch-headless` session — the agent
# runs identically (TTY provided by tmux, hooks fire normally) but isn't visible
# until promoted with `orch-show <pane_id>`.
#
# With --outfit (claude only for now), runs `suit prepare` to generate an
# isolated config bundle in a tempdir, then spawns claude with the project
# as cwd (so the project's CLAUDE.md auto-loads) and the bundle as `--add-dir`
# for skills/agents/hooks. Because `--add-dir` does NOT auto-load
# `<dir>/CLAUDE.md`, the bundle's CLAUDE.md is merged with the fleet doctrine
# into a single `--append-system-prompt-file`. The wrap traps EXIT so the
# bundle (and merged file inside it) is auto-removed when the pane dies. This
# gives per-worker outfit isolation even when multiple workers share the same
# project.
#
# Output contract: stdout is exactly one line — the new pane id. All
# informational and error output goes to stderr. Pass --quiet to suppress
# stderr too (caller signs up for silent failure on non-zero exit).
# Pane metadata (agent, role, cwd) is published to $SRV.INFO.agents by the
# orch-agent-shim that starts alongside the worker.
#
# suit interop: prefers `suit prepare --quiet` (v0.10+) for clean bundle-path
# capture; falls back to legacy stdout-tail capture on older suit so the
# spawn keeps working without forcing a suit upgrade.
set -euo pipefail

AGENT=${1:-}
shift 2>/dev/null || true
[ -n "$AGENT" ] || { echo "usage: orch-spawn <agent> [--cwd p] [--sesh-session label] [--project n] [--headless] [--no-fleet] [--quiet] [--role worker|observer] [--position right|left|above|below] [--verify] [--outfit X] [--cut Y] [--accessory A] [--no-shim] [--executor tmux|wasm]    env: [ORCH_SESH_BIN=<abs-path>] [ORCH_PROJECTS_ROOT=<dir>] [ORCH_VERIFY_TIMEOUT=<sec>] [ORCH_HEADLESS_SESSION=<name>]" >&2; exit 1; }

CWD=""
SESH_SESSION_FLAG=""
CWD_FROM_FLAG=0
PROJECT=""
HEADLESS=0
NO_FLEET=0
QUIET=0
ROLE_OVERRIDE=""
POSITION="right"
VERIFY=0
OUTFIT=""
CUT=""
ACCESSORIES=()
NO_GOAL_ACCESSORY=0
NO_SHIM=0
EXECUTOR="tmux"

while [ $# -gt 0 ]; do
    case $1 in
        --cwd) CWD=$2; CWD_FROM_FLAG=1; shift 2 ;;
        --sesh-session) SESH_SESSION_FLAG=$2; shift 2 ;;
        --project) PROJECT=$2; shift 2 ;;
        --headless) HEADLESS=1; shift ;;
        --no-fleet) NO_FLEET=1; shift ;;
        --quiet) QUIET=1; exec 2>/dev/null; shift ;;
        --role)
            ROLE_OVERRIDE=${2:-}
            case "$ROLE_OVERRIDE" in
                worker|observer) ;;
                *) echo "orch-spawn: --role must be worker or observer (got: $ROLE_OVERRIDE)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        --position)
            POSITION=${2:-}
            case "$POSITION" in
                right|left|above|below) ;;
                *) echo "orch-spawn: --position must be right|left|above|below (got: $POSITION)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        --verify) VERIFY=1; shift ;;
        --outfit) OUTFIT=$2; shift 2 ;;
        --cut) CUT=$2; shift 2 ;;
        --accessory) ACCESSORIES+=("$2"); shift 2 ;;
        --no-goal-accessory) NO_GOAL_ACCESSORY=1; shift ;;
        --no-shim) NO_SHIM=1; shift ;;
        --executor)
            EXECUTOR=${2:-}
            case "$EXECUTOR" in
                tmux|wasm) ;;
                *) echo "orch-spawn: --executor must be tmux|wasm (got: $EXECUTOR)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        *) echo "orch-spawn: unknown flag: $1" >&2; exit 1 ;;
    esac
done

[ $QUIET -eq 1 ] && exec 2>/dev/null

# Resolve role: explicit --role wins; otherwise auto-detect from outfit/cut.
# Observer-class outfits/cuts are meta panes (spies, auditors) — they watch
# rather than do work, and bus subscribers filter them by metadata.role.
ROLE="$ROLE_OVERRIDE"
if [ -z "$ROLE" ]; then
    case "$OUTFIT" in
        stasi) ROLE=observer ;;
    esac
fi
if [ -z "$ROLE" ]; then
    case "$CUT" in
        wait-watch|spy-on-*) ROLE=observer ;;
    esac
fi
[ -z "$ROLE" ] && ROLE=worker

# --sesh-session resolution: ask sesh's worker-cwd helper for the fossil
# checkout dir. This is the worker-side leg of the fossil-as-trunk swarm
# workflow (sesh issue #64) — the worker lands inside a provisioned
# checkout under <project>/.sesh/checkouts/<label>/.
#
# Mutually exclusive with --cwd: passing both is operator confusion (the
# whole point of --sesh-session is "I don't know the checkout path,
# resolve it for me"). We check CWD_FROM_FLAG rather than [ -n "$CWD" ]
# because $CWD may have been seeded by a later --project resolution, and
# we want the conflict caught against the explicit flag, not against an
# implicit default.
#
# Resolution shells out to `sesh worker-cwd <label>`. Override the binary
# location via ORCH_SESH_BIN (default: `sesh` on PATH). The override path
# is mainly for tests — a CI build of sesh that hasn't been installed to
# PATH yet. On error we surface sesh's stderr verbatim so the operator
# sees the actual remediation hint (e.g. "run 'sesh worktree <label>'").
if [ -n "$SESH_SESSION_FLAG" ]; then
    if [ $CWD_FROM_FLAG -eq 1 ]; then
        echo "orch-spawn: --cwd and --sesh-session are mutually exclusive (got --cwd=$CWD, --sesh-session=$SESH_SESSION_FLAG)" >&2
        exit 1
    fi
    # Resolve ORCH_SESH_BIN to an absolute path BEFORE any cd. orch-spawn
    # later changes directory (via the executor's WRAP and via subshells
    # like `cd "$CWD" && pwd -P`); a relative ORCH_SESH_BIN would resolve
    # against whichever cwd happened to be active at call time, which is
    # confusing and brittle. `command -v` returns an absolute path when the
    # arg is a bare name on PATH; otherwise we accept the operator-supplied
    # path and require it to be executable.
    SESH_BIN_INPUT=${ORCH_SESH_BIN:-sesh}
    SESH_BIN=""
    case "$SESH_BIN_INPUT" in
        /*)
            # Already absolute — verify it's executable.
            [ -x "$SESH_BIN_INPUT" ] && SESH_BIN=$SESH_BIN_INPUT ;;
        */*)
            # Relative path with directory component — resolve against pwd
            # NOW (before any cd) and verify executable.
            _resolved=$(cd "$(dirname "$SESH_BIN_INPUT")" 2>/dev/null && pwd -P)/$(basename "$SESH_BIN_INPUT")
            [ -x "$_resolved" ] && SESH_BIN=$_resolved ;;
        *)
            # Bare name — look up on PATH. `command -v` returns the absolute
            # path for binaries it finds.
            SESH_BIN=$(command -v "$SESH_BIN_INPUT" 2>/dev/null || true) ;;
    esac
    if [ -z "$SESH_BIN" ] || [ ! -x "$SESH_BIN" ]; then
        echo "orch-spawn: --sesh-session needs the 'sesh' binary on PATH (or set ORCH_SESH_BIN=<absolute-path>) — got '$SESH_BIN_INPUT' — install from https://github.com/danmestas/sesh" >&2
        exit 1
    fi
    SESH_STDERR=$(mktemp)
    if SESH_CWD_RESOLVED=$("$SESH_BIN" worker-cwd "$SESH_SESSION_FLAG" 2>"$SESH_STDERR"); then
        :
    else
        SESH_RC=$?
        echo "orch-spawn: sesh worker-cwd $SESH_SESSION_FLAG failed (exit $SESH_RC): $(cat "$SESH_STDERR")" >&2
        rm -f "$SESH_STDERR"
        exit 1
    fi
    rm -f "$SESH_STDERR"
    # sesh prints exactly one line: the absolute checkout path. Trim any
    # trailing newline defensively.
    SESH_CWD_RESOLVED=$(printf '%s' "$SESH_CWD_RESOLVED" | tr -d '\n')
    if [ -z "$SESH_CWD_RESOLVED" ]; then
        echo "orch-spawn: sesh worker-cwd $SESH_SESSION_FLAG returned empty stdout" >&2
        exit 1
    fi
    CWD=$SESH_CWD_RESOLVED
fi

# Resolve --project to a directory:
#   1. zoxide query (if zoxide is installed and the name is indexed)
#   2. ~/projects/<name> (fallback for users without zoxide, or projects
#      not yet indexed in zoxide)
# Override the fallback root via ORCH_PROJECTS_ROOT (default: ~/projects).
if [ -n "$PROJECT" ] && [ -z "$CWD" ]; then
    if command -v zoxide >/dev/null 2>&1; then
        CWD=$(zoxide query "$PROJECT" 2>/dev/null || true)
    fi
    if [ -z "$CWD" ]; then
        FALLBACK="${ORCH_PROJECTS_ROOT:-$HOME/projects}/$PROJECT"
        if [ -d "$FALLBACK" ]; then
            CWD=$FALLBACK
        else
            echo "orch-spawn: cannot resolve --project $PROJECT — not in zoxide and not at $FALLBACK" >&2
            exit 1
        fi
    fi
fi
[ -z "$CWD" ] && CWD=$(pwd)

# Reject CWD values that would let a path craft shell injection into the
# spawned pane. The WRAP runs via /bin/sh -c with $CWD interpolated into
# `cd "$CWD"` and (for codex) a quoted -c argument. A path containing
# quotes, dollar-paren, backticks, or backslashes can break out of the
# quoting and execute arbitrary commands in the spawned shell. These
# characters are pathologically rare in real project paths; refuse early
# rather than ship an injection surface.
case "$CWD" in
    *[\"\'\$\\\`]*)
        echo "orch-spawn: unsafe characters in cwd ($CWD) — refusing to build a shell-injection-prone WRAP" >&2
        exit 1
        ;;
esac

# Auto-add the sesh-goal accessory when the operator is in an active goal
# pursuit. The accessory's hooks no-op when SESH_GOAL_ID isn't set, so the
# only cost of including it is a few extra files in the worker's bundle.
# Skip if --no-goal-accessory was passed, or if the operator already added
# it explicitly.
if [ -n "${SESH_GOAL_ID:-}" ] && [ -n "$OUTFIT" ] && [ $NO_GOAL_ACCESSORY -eq 0 ]; then
    HAVE_GOAL_ACC=0
    for a in "${ACCESSORIES[@]}"; do
        [ "$a" = "sesh-goal" ] && HAVE_GOAL_ACC=1
    done
    if [ $HAVE_GOAL_ACC -eq 0 ]; then
        ACCESSORIES+=("sesh-goal")
        echo "orch-spawn: SESH_GOAL_ID set in parent — auto-adding --accessory=sesh-goal (use --no-goal-accessory to opt out)" >&2
    fi
fi

# Outfit support: only claude has been verified end-to-end (test-suit-integration.sh).
# For other agents, suit's adapters emit different content per --target; wiring
# them up needs its own verification round.
BUNDLE=""
if [ -n "$OUTFIT" ]; then
    [ "$AGENT" = claude ] || { echo "orch-spawn: --outfit currently only supported for agent=claude (saw: $AGENT)" >&2; exit 1; }
    command -v suit >/dev/null 2>&1 || { echo "orch-spawn: suit not on PATH — install @agent-ops/suit" >&2; exit 1; }
    SUIT_CMD=(suit prepare --outfit "$OUTFIT" --target claude-code)
    [ -n "$CUT" ] && SUIT_CMD+=(--cut "$CUT")
    for a in "${ACCESSORIES[@]}"; do SUIT_CMD+=(--accessory "$a"); done
    # Prefer --quiet (suit v0.10+) for clean stdout=bundle-path; fall back to
    # legacy stdout-tail capture if suit doesn't recognize the flag.
    if BUNDLE=$("${SUIT_CMD[@]}" --quiet 2>/dev/null); then
        :
    elif LEGACY_OUT=$("${SUIT_CMD[@]}" 2>/dev/null); then
        BUNDLE=$(printf '%s\n' "$LEGACY_OUT" | tail -1)
    else
        BUNDLE=""
    fi
    [ -d "$BUNDLE" ] || { echo "orch-spawn: suit prepare failed (no bundle path returned)" >&2; exit 1; }
fi

# Build the env-export prefix for the worker's WRAP. ORCH_PANE_ID always.
# When the operator has an active goal pursuit, propagate the SESH_GOAL_*
# vars so the sesh-goal hooks activate in the worker's session.
#
# GOAL_EXPORTS is a shell fragment embedded into WRAP (the command string
# passed to `tmux split-window`). Values are inlined at build time (not
# referenced as \$VAR) because they must resolve in the parent's context,
# not the new pane's fresh env. We build the fragment via printf -v with
# %q so the values are shell-quoted by bash itself — robust against any
# shell metacharacters in the source vars, and shellcheck-clean (no
# SC2089/SC2090 because the quoting is delegated to printf).
GOAL_EXPORTS=""
goal_append() {
    local name=$1 value=$2 chunk
    printf -v chunk " export %s=%q;" "$name" "$value"
    GOAL_EXPORTS="${GOAL_EXPORTS}${chunk}"
}
if [ -n "${SESH_GOAL_ID:-}" ]; then
    goal_append SESH_GOAL_ID "$SESH_GOAL_ID"
    [ -n "${SESH_GOAL_SCOPE:-}" ]    && goal_append SESH_GOAL_SCOPE    "$SESH_GOAL_SCOPE"
    [ -n "${SESH_GOAL_SCOPE_ID:-}" ] && goal_append SESH_GOAL_SCOPE_ID "$SESH_GOAL_SCOPE_ID"
fi

# Locate the executor script relative to this binary. When orch-spawn is a
# symlink (e.g. ~/.local/bin/orch-spawn → /path/to/repo/bin/orch-spawn), we
# must resolve the symlink to find the repo root. readlink -f / realpath both
# work on Linux; on macOS use the pwd -P trick via a subshell.
_SELF="${BASH_SOURCE[0]}"
# Follow up to 5 levels of symlinks (avoids an infinite-loop on broken setups).
for _i in 1 2 3 4 5; do
    [ -L "$_SELF" ] || break
    _SELF=$(readlink "$_SELF")
    # Relative symlinks need resolving against the link's directory.
    case "$_SELF" in
        /*) ;;
        *) _SELF="$(dirname "${BASH_SOURCE[0]}")/$_SELF" ;;
    esac
done
ORCH_REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd -P)"
SPAWN_SCRIPT="${ORCH_REPO_ROOT}/executors/${EXECUTOR}/spawn.sh"
[ -x "$SPAWN_SCRIPT" ] || { echo "orch-spawn: executor script not found or not executable: $SPAWN_SCRIPT" >&2; exit 1; }

# Delegate to the executor. All resolved state is exported so the executor
# script can read it without re-parsing args. stdout from the executor is the
# pane id; we capture it for the shim launch downstream.
PANE=$(export AGENT CWD HEADLESS NO_FLEET POSITION VERIFY OUTFIT BUNDLE GOAL_EXPORTS NO_SHIM ROLE; \
      bash "$SPAWN_SCRIPT")

# Shim launch: start orch-agent-shim alongside the pane unless --no-shim.
# The shim registers the pane on the Synadia Agent Protocol bus so callers
# can discover it via $SRV.INFO.agents and prompt it over NATS.
#
# Env vars are exported explicitly into the background process rather than
# inherited implicitly — disown/nohup detach the process from the shell's
# job table but the env block is already resolved in the parent before the
# fork, so all five vars (ORCH_OWNER, ORCH_OUTFIT, ORCH_ROLE, SESH_SESSION,
# NATS_URL) are correct in both bash and zsh.
#
# Adapter-less harnesses (codex/pi/gemini until Plans 11-13): orch-agent-shim
# exits 2 when invoked with an unknown adapter. We detect this by probing
# --agent before the real launch; if the exit is 2, we skip the shim and
# emit a warning (the legacy marker-hook fallback was retired in #94). Exit
# != 2 → try anyway; the shim surfaces real errors in its log (no point
# pre-empting an unclear failure).
#
# Stderr goes to ~/.cache/orch-shim/<pane_id>.log (pane id has %, use
# pct-form in path). Stdout is discarded (not part of spawn output contract).
if [ $NO_SHIM -eq 0 ]; then
    if command -v orch-agent-shim >/dev/null 2>&1; then
        # Translate agent name into the canonical Synadia identifier so
        # metadata.agent matches Appendix C. orch-spawn accepts "claude"
        # as the harness arg; Synadia knows it as "claude-code".
        case "$AGENT" in
            claude) SHIM_AGENT="claude-code" ;;
            *)      SHIM_AGENT="$AGENT" ;;
        esac

        # Probe: does this agent have a loaded adapter? orch-agent-shim --help
        # exits 0 for known adapters and 2 for unknown ones (adapter-not-found).
        # We use --help with an explicit --agent to trigger adapter selection
        # without actually running the shim.
        ADAPTER_EXIT=0
        if orch-agent-shim --agent "$SHIM_AGENT" --help >/dev/null 2>&1; then
            ADAPTER_OK=1
        else
            ADAPTER_EXIT=$?
            if [ "$ADAPTER_EXIT" -eq 2 ]; then
                ADAPTER_OK=0
            else
                ADAPTER_OK=1  # unexpected exit — try anyway; shim will surface error in log
            fi
        fi

        if [ $ADAPTER_OK -eq 1 ]; then
            # Resolve the five env vars that the shim needs. Inlined here
            # (not \$VAR references) so they resolve in the parent's context
            # and survive disown in both bash and zsh.
            SHIM_OWNER="${SESH_OWNER:-${USER:-$(id -un)}}"
            SHIM_SESSION="${SESH_SESSION:-}"
            SHIM_NATS="${NATS_URL:-}"

            # Log dir: use pct-form of pane id (% → pct) for safe filename.
            PANE_SAFE="${PANE//%/pct}"
            SHIM_LOG_DIR="$HOME/.cache/orch-shim"
            mkdir -p "$SHIM_LOG_DIR"
            SHIM_LOG="$SHIM_LOG_DIR/${PANE_SAFE}.log"

            ORCH_OWNER="$SHIM_OWNER" \
            ORCH_OUTFIT="$OUTFIT" \
            ORCH_ROLE="$ROLE" \
            SESH_SESSION="$SHIM_SESSION" \
            NATS_URL="$SHIM_NATS" \
            orch-agent-shim \
                --agent "$SHIM_AGENT" \
                --pane "$PANE" \
                --cwd "$CWD" \
                >"$SHIM_LOG" 2>&1 &
            disown
        else
            echo "orch-spawn: no shim adapter for $AGENT (adapter-less harness) — spawning without shim; bus integration is disabled for this pane" >&2
        fi
    else
        echo "orch-spawn: orch-agent-shim not on PATH — spawning without shim; install via install.sh to enable bus integration" >&2
    fi
fi

echo "$PANE"
