#!/usr/bin/env bash
# orch-spawn — dispatcher: parses args, selects executor, delegates spawn.
#
# Usage:
#   orch-spawn <agent> [--cwd <path>] [--sesh-session <label>] [--project <name>]
#                         [--worktree-from <sha>] [--slug <name>]
#                         [--instance-id <name>] [--force-slug]
#                         [--headless] [--no-fleet]
#                         [--quiet] [--role <worker|observer>]
#                         [--position <right|left|above|below>] [--verify]
#                         [--outfit <name>] [--cut <name>] [--accessory <name>]...
#                         [--no-shim] [--executor <name>]
#
# Environment variables:
#   ORCH_SESH_BIN          — absolute path to the `sesh` binary (default: first
#                            `sesh` on PATH). Must be absolute; orch-spawn `cd`s
#                            during resolution, so a relative path can break
#                            silently. Resolved early — error surfaces before
#                            any pane is spawned.
#   ORCH_PROJECTS_ROOT     — fallback root for `--project <name>` lookups when
#                            zoxide miss (default: $HOME/projects).
#   ORCH_VERIFY_TIMEOUT    — total readiness poll budget for --verify
#                            (default: 60s). Caps the cumulative wall time
#                            across all retry attempts.
#   ORCH_VERIFY_BACKOFF    — comma-separated wait sequence between --verify
#                            attempts (default: `1,2,4,8`). Each entry is the
#                            number of seconds to wait BEFORE the next
#                            readiness probe. Total time capped by
#                            ORCH_VERIFY_TIMEOUT; fail-fast on pane death or
#                            missing harness binary.
#   ORCH_HEADLESS_SESSION  — name of the detached headless tmux session
#                            (default: orch-headless).
#   ORCH_WORKTREE_ROOT     — directory under which --worktree-from creates new
#                            worktrees (default:
#                            ${ORCH_PROJECTS_ROOT:-$HOME/projects}/<repo>-worktrees/).
#   ORCH_ALIASES_FILE      — alias file written by --slug (default:
#                            ~/.config/orch-aliases). Each --slug appends a
#                            `<slug>=<pane_id>` line so other harnesses can
#                            resolve the worker by name.
#   ORCH_NO_PAUSE_ON_EXIT  — when set to 1, the spawned wrapper omits its
#                            trailing `read; exec $SHELL -l` (the
#                            "[agent exited — press enter]" pause +
#                            shell-fallback). Use in CI / test contexts
#                            where the agent's death should close the
#                            pane cleanly; the interactive default
#                            (unset/0) preserves the pause-and-inspect
#                            behaviour operators expect. Closes #178 —
#                            the read otherwise blocks indefinitely and
#                            survives `tmux kill-pane`, leaking zombies.
#
# --sesh-session <label> sets the worker's cwd to the fossil checkout
# provisioned by `sesh worktree <label>` — the worker-side leg of the
# fossil-as-trunk swarm workflow (sesh issue #64). orch-spawn shells out
# to `sesh worker-cwd <label>` and uses the printed path as the cwd, so
# the worker lands in <project>/.sesh/checkouts/<label>/ with a live
# fossil checkout ready for fossil commit / fossil update. Mutually
# exclusive with --cwd; pass one or the other, not both.
#
# Executor selection (--executor, default: tmux):
#   The dispatcher resolves an executor name (e.g., tmux, cf-worker,
#   cf-durable-object) via hybrid discovery, in this order:
#     1. ORCH_EXECUTOR_<NAME>_CMD env var  — operator override; a shell
#        command string interpreted by `bash -c` in the spawn subshell
#        (e.g., ORCH_EXECUTOR_CF_WORKER_CMD="curl -X POST https://my-cf.dev").
#     2. `command -v orch-executor-<name>` — PATH binary installed by a
#        sister-repo release (npm/brew/goreleaser per Proposal 0003).
#     3. ${ORCH_REPO_ROOT}/executors/<name>/spawn.sh — in-tree fallback;
#        preserves backward compat during the gradual cutover.
#   tmux stays in-tree per the 2026-05-18 Ousterhout review (Proposal 0003
#   §"Ousterhout-review adjustment"). Future heavyweight backends live in
#   sister repos and ship via PATH or env-override.
#
# orch-agent-shim is launched by default alongside every spawned pane,
# registering it as a Synadia Agent Protocol v0.3 agent on the sesh hub
# (or $NATS_URL). The shim publishes heartbeats and accepts prompts on
# agents.prompt.cc.<owner>.pct<pane>. Pass --no-shim to disable (useful
# for diagnostics or when orch-agent-shim has no adapter for the target
# harness). The shim is silently skipped if `orch-agent-shim` isn't on
# PATH (warning to stderr, spawn proceeds — keeps install graceful for
# shell-only orchs). Harnesses without a loaded adapter (codex/pi/gemini
# until Plans 11-13) spawn with the shim disabled and a warning; the legacy
# marker-hook fallback was retired in #94 (Synadia is the only path).
#
# Bridge selection (--bridge, claude only — Proposal 0010 / issue #182):
#   synadia-plugin (default for claude) — load the Synadia nats-channel
#                  plugin inside claude via --dangerously-load-development-channels.
#                  The plugin bridges claude-code natively to NATS (in-process
#                  MCP tool + channel push); no orch-agent-shim sidecar is
#                  launched. Requires a one-time
#                  `/plugin install nats-channel@synadia-plugins` per machine.
#   shim-adapter   — legacy path: launch orch-agent-shim alongside the pane
#                    with the claude-code JSONL/send-keys adapter. Use as a
#                    fallback when the plugin isn't installed locally, or
#                    for environments that can't load development channels.
# Codex/pi/gemini stay on shim-adapter and reject --bridge=synadia-plugin
# until Synadia ships equivalent plugins (Phase B builds a NATS↔ACP bridge
# for them). --no-shim still wins over both bridge modes (disables all bus
# integration).
#
# --position controls where the new pane is split off the current pane in headed
# mode. Default `right` preserves prior behavior (tmux split-window -h). Mapping:
# right=`-h`, left=`-h -b`, above=`-v -b`, below=`-v`. Ignored in --headless.
#
# --verify polls the new pane after the split for either of two readiness
# signals: (1) pane_current_command becomes anything other than a known
# shell (zsh|bash|sh|fish|dash|ksh) — agents like claude rename their
# process title once launched; or (2) the pane's visible buffer contains a
# per-agent banner string. The second signal absorbs cold-start variance
# when an agent's REPL is interactive before the title rename catches up
# (heavy outfits with many MCP servers / hooks routinely cross the title
# threshold late). The pane dying still counts as a failure. Default
# budget is 60s, overridable via ORCH_VERIFY_TIMEOUT. Retries follow the
# ORCH_VERIFY_BACKOFF sequence (default `1,2,4,8` — exponential up to the
# total timeout) so a slow cold start can succeed on a later attempt
# without dragging the failure case out to the full timeout. Fail-fast on
# pane death or "command not found" output for the harness binary. On
# success, emits one stderr line "orch-spawn: agent ready in pane %X
# (attempt N/M, Ts)". On failure, emits "orch-spawn: verify failed after
# N attempts" (or "pane died" / "binary missing") and exits non-zero —
# useful for catching the silent-shell-pane failure mode where the agent
# CLI never actually launches.
#
# Examples:
#   orch-spawn claude --project gonvex
#   orch-spawn pi --cwd ~/projects/bones
#   orch-spawn codex --project dagnats --headless
#   orch-spawn claude --project bones --outfit engineer --cut focused
#   orch-spawn claude --outfit stasi --cut wait-watch       # auto role=observer
#   orch-spawn claude --role observer --outfit engineer     # explicit override
#
# Role: panes are tagged role=worker by default; role=observer when the outfit
# or cut indicates a meta/spy class (stasi outfit, wait-watch cut, spy-on-* cut)
# OR when --role is passed. Subscribers on the Synadia bus can filter on the
# shim's metadata.role field; explicit --role wins over auto-detection.
#
# Default: spawns in the orchestrator's tmux window (headed).
# With --headless, spawns in the detached `orch-headless` session — the agent
# runs identically (TTY provided by tmux, hooks fire normally) but isn't visible
# until promoted with `orch-show <pane_id>`.
#
# With --outfit (claude only for now), runs `suit prepare` to generate an
# isolated config bundle in a tempdir, then spawns claude with the project
# as cwd (so the project's CLAUDE.md auto-loads) and the bundle as `--add-dir`
# for skills/agents/hooks. Because `--add-dir` does NOT auto-load
# `<dir>/CLAUDE.md`, the bundle's CLAUDE.md is merged with the fleet doctrine
# into a single `--append-system-prompt-file`. The wrap traps EXIT so the
# bundle (and merged file inside it) is auto-removed when the pane dies. This
# gives per-worker outfit isolation even when multiple workers share the same
# project.
#
# Output contract: stdout is exactly one line — the new pane id. All
# informational and error output goes to stderr. Pass --quiet to suppress
# stderr too (caller signs up for silent failure on non-zero exit).
# Pane metadata (agent, role, cwd) is published to $SRV.INFO.agents by the
# orch-agent-shim that starts alongside the worker.
#
# suit interop: prefers `suit prepare --quiet` (v0.10+) for clean bundle-path
# capture; falls back to legacy stdout-tail capture on older suit so the
# spawn keeps working without forcing a suit upgrade.
#
# --worktree-from <sha> + --slug <name>:
#   The slug is a worker-identity concept; the worktree is a filesystem
#   concept. The two flags are decoupled so callers can mix-and-match:
#
#   - Both set:   create worktree at <sha> under
#                 ${ORCH_WORKTREE_ROOT}/<slug>; pane gets <slug> as its
#                 title; ~/.config/orch-aliases gets a `<slug>=<pane_id>`
#                 line so other harnesses can resolve by name.
#   - --slug only:        cwd is unchanged; the pane is still labeled and
#                         the alias is still written (useful for tagging a
#                         worker spawned in the current repo).
#   - --worktree-from only: an auto-slug `<sha7>-<rand4>` is synthesized
#                         and used for both the worktree dir name and the
#                         label.
#   - Neither:    legacy behaviour (no worktree, no label, no alias).
#
#   --worktree-from is mutually exclusive with --cwd and --sesh-session
#   (those flags pick their own checkout strategy; the worktree creator
#   would just stomp them). --slug carries no checkout semantics on its
#   own and composes freely with --cwd / --sesh-session / --project.
#
# --instance-id <name> (Proposal 0009 / issue #181):
#   Synonym for --slug — the worker's stable identity on the Synadia
#   Agent Protocol bus. Passed straight through to
#   `synadia-agent-shim --instance-id <slug>`, which uses it as the
#   primary subject-token in agents.{prompt,status}.<token>.<owner>.<slug>
#   (the pct-keyed legacy track stays live until ORCH_SLUG_DUAL_PUBLISH=0).
#   When neither --slug nor --instance-id is given, orch-spawn derives the
#   slug from $SESH_SESSION (if set in the parent shell) so workers spawned
#   inside a sesh session inherit a stable identity automatically. When no
#   slug source is available at all, the spawn proceeds with a warning
#   (legacy pct-keyed identity only) — operators get a release to migrate.
#
# --force-slug:
#   By default a slug that already maps to a different pane in the alias
#   file is refused (so two workers can't claim the same name and stomp
#   each other's bus identity). --force-slug bypasses the collision check
#   and overwrites the alias-file entry; the previous worker on that slug
#   keeps running but loses its alias.
set -euo pipefail

AGENT=${1:-}
shift 2>/dev/null || true
[ -n "$AGENT" ] || { echo "usage: orch-spawn <agent> [--cwd p] [--sesh-session label] [--project n] [--worktree-from sha] [--slug name] [--instance-id name] [--force-slug] [--headless] [--no-fleet] [--quiet] [--role worker|observer] [--class active|observer] [--position right|left|above|below] [--verify] [--outfit X] [--cut Y] [--accessory A] [--no-shim] [--bridge synadia-plugin|shim-adapter] [--executor <name>] [--persistence <name>] [--layout <name>]    env: [ORCH_SESH_BIN=<abs-path>] [ORCH_PROJECTS_ROOT=<dir>] [ORCH_VERIFY_TIMEOUT=<sec>] [ORCH_VERIFY_BACKOFF=1,2,4,8] [ORCH_HEADLESS_SESSION=<name>] [ORCH_WORKTREE_ROOT=<dir>] [ORCH_ALIASES_FILE=<path>] [ORCH_ENGINES_BIN=<abs-path>]" >&2; exit 1; }

CWD=""
SESH_SESSION_FLAG=""
CWD_FROM_FLAG=0
PROJECT=""
WORKTREE_FROM=""
WORKTREE_FROM_FLAG=0
SLUG=""
SLUG_FROM_FLAG=0
FORCE_SLUG=0
HEADLESS=0
NO_FLEET=0
QUIET=0
ROLE_OVERRIDE=""
CLASS_OVERRIDE=""
POSITION="right"
VERIFY=0
OUTFIT=""
CUT=""
ACCESSORIES=()
NO_GOAL_ACCESSORY=0
NO_SHIM=0
EXECUTOR="tmux"
BRIDGE=""
# Engine selection (Proposal 0008 / issue #180). Phase A: persistence
# and layout are orthogonal axes that today's tmux bundles. The closed
# composition table (in `orch-engines validate`) is the single source
# of truth for which pairs are supported. Defaults match today's
# behavior so legacy invocations are unchanged.
PERSISTENCE="tmux"
LAYOUT="tmux"

while [ $# -gt 0 ]; do
    case $1 in
        --cwd) CWD=$2; CWD_FROM_FLAG=1; shift 2 ;;
        --sesh-session) SESH_SESSION_FLAG=$2; shift 2 ;;
        --project) PROJECT=$2; shift 2 ;;
        --worktree-from) WORKTREE_FROM=$2; WORKTREE_FROM_FLAG=1; shift 2 ;;
        --slug) SLUG=$2; SLUG_FROM_FLAG=1; shift 2 ;;
        --instance-id) SLUG=$2; SLUG_FROM_FLAG=1; shift 2 ;;
        --force-slug) FORCE_SLUG=1; shift ;;
        --headless) HEADLESS=1; shift ;;
        --no-fleet) NO_FLEET=1; shift ;;
        --quiet) QUIET=1; exec 2>/dev/null; shift ;;
        --role)
            ROLE_OVERRIDE=${2:-}
            case "$ROLE_OVERRIDE" in
                worker|observer) ;;
                *) echo "orch-spawn: --role must be worker or observer (got: $ROLE_OVERRIDE)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        --class)
            CLASS_OVERRIDE=${2:-}
            shift 2 ;;
        --class=*)
            CLASS_OVERRIDE="${1#--class=}"
            shift ;;
        --position)
            POSITION=${2:-}
            case "$POSITION" in
                right|left|above|below) ;;
                *) echo "orch-spawn: --position must be right|left|above|below (got: $POSITION)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        --verify) VERIFY=1; shift ;;
        --outfit) OUTFIT=$2; shift 2 ;;
        --cut) CUT=$2; shift 2 ;;
        --accessory) ACCESSORIES+=("$2"); shift 2 ;;
        --no-goal-accessory) NO_GOAL_ACCESSORY=1; shift ;;
        --no-shim) NO_SHIM=1; shift ;;
        --bridge)
            BRIDGE=${2:-}
            case "$BRIDGE" in
                synadia-plugin|shim-adapter) ;;
                *) echo "orch-spawn: --bridge must be synadia-plugin|shim-adapter (got: $BRIDGE)" >&2; exit 1 ;;
            esac
            shift 2 ;;
        --bridge=*)
            BRIDGE="${1#--bridge=}"
            case "$BRIDGE" in
                synadia-plugin|shim-adapter) ;;
                *) echo "orch-spawn: --bridge must be synadia-plugin|shim-adapter (got: $BRIDGE)" >&2; exit 1 ;;
            esac
            shift ;;
        --executor)
            EXECUTOR=${2:-}
            # Executor name must be a stable identifier — lowercase letters,
            # digits, hyphens; starts with a letter. Used to construct env
            # var names (ORCH_EXECUTOR_<NAME>_CMD), PATH binary names
            # (orch-executor-<name>), and in-tree paths (executors/<name>/).
            # All three need a safe character set; this is the intersection.
            case "$EXECUTOR" in
                ''|*[!a-z0-9-]*|[!a-z]*)
                    echo "orch-spawn: --executor must match [a-z][a-z0-9-]* (got: $EXECUTOR)" >&2
                    exit 1 ;;
            esac
            shift 2 ;;
        --persistence)
            PERSISTENCE=${2:-}
            # Persistence engine name follows the same shape rule as
            # --executor. Composition validity is checked separately
            # (orch-engines validate) so this layer only enforces
            # well-formed-ness.
            case "$PERSISTENCE" in
                ''|*[!a-z0-9-]*|[!a-z]*)
                    echo "orch-spawn: --persistence must match [a-z][a-z0-9-]* (got: $PERSISTENCE)" >&2
                    exit 1 ;;
            esac
            shift 2 ;;
        --layout)
            LAYOUT=${2:-}
            # Layout engine name follows the same shape rule.
            case "$LAYOUT" in
                ''|*[!a-z0-9-]*|[!a-z]*)
                    echo "orch-spawn: --layout must match [a-z][a-z0-9-]* (got: $LAYOUT)" >&2
                    exit 1 ;;
            esac
            shift 2 ;;
        *) echo "orch-spawn: unknown flag: $1" >&2; exit 1 ;;
    esac
done

[ $QUIET -eq 1 ] && exec 2>/dev/null

# Validate --class override up-front: bail before any further resolution so the
# error path is clean. Empty CLASS_OVERRIDE means "no override; derive below".
if [ -n "$CLASS_OVERRIDE" ] && [ "$CLASS_OVERRIDE" != "active" ] && [ "$CLASS_OVERRIDE" != "observer" ]; then
    printf 'orch-spawn: --class must be "active" or "observer", got %q\n' "$CLASS_OVERRIDE" >&2
    exit 2
fi

# Validate the (persistence, layout) composition against the closed
# registry — Proposal 0008 / issue #180. Rejected pairs fail at
# flag-parse, NOT at spawn time, so operators see the error before any
# tmux/spawn work happens.
#
# The Go binary orch-engines owns the registry; we shell out so the
# bash dispatcher doesn't duplicate the table (single source of truth).
#
# Discovery order:
#   1. $ORCH_ENGINES_BIN   — operator override (mainly tests).
#   2. orch-engines on PATH — production install.
#   3. `go run ./cmd/orch-engines` from repo root — dev mode, no install
#      needed.
#
# When NONE of the three resolve (extremely unusual), we accept the
# default (tmux,tmux) pair without validation as a graceful fallback so
# legacy invocations don't break on a fresh checkout. Any non-default
# composition under that fallback bails — better to refuse a spawn
# than to silently accept an unsupported pair.
validate_composition() {
    local p=$1 l=$2 engines_bin=""
    if [ -n "${ORCH_ENGINES_BIN:-}" ] && [ -x "$ORCH_ENGINES_BIN" ]; then
        engines_bin="$ORCH_ENGINES_BIN"
    elif command -v orch-engines >/dev/null 2>&1; then
        engines_bin=$(command -v orch-engines)
    fi
    if [ -n "$engines_bin" ]; then
        if ! "$engines_bin" validate "$p" "$l"; then
            return 1
        fi
        return 0
    fi
    # Dev fallback: go run from repo root. Slower (build per call) but
    # works on a fresh checkout. We discover the repo root the same
    # way as the executor resolution below — see _SELF / ORCH_REPO_ROOT
    # block. Replicating just enough of that here to avoid a forward
    # dep; the canonical resolution happens later when we run the
    # spawn script.
    local self=$0
    local _i
    for _i in 1 2 3 4 5; do
        [ -L "$self" ] || break
        local next
        next=$(readlink "$self")
        case "$next" in /*) self=$next ;; *) self="$(dirname "$self")/$next" ;; esac
    done
    # _i is a loop bound, not used inside the loop — shellcheck-clean.
    : "$_i"
    local repo_root
    repo_root="$(cd "$(dirname "$self")/.." && pwd -P)"
    if [ -f "$repo_root/cmd/orch-engines/main.go" ] && command -v go >/dev/null 2>&1; then
        if ! (cd "$repo_root" && go run ./cmd/orch-engines validate "$p" "$l"); then
            return 1
        fi
        return 0
    fi
    # Final fallback: only the default pair is accepted without
    # validation. Any other pair is refused.
    if [ "$p" = "tmux" ] && [ "$l" = "tmux" ]; then
        return 0
    fi
    echo "orch-spawn: orch-engines binary not found and no go toolchain available; cannot validate composition (persistence=$p layout=$l). Install orch via install.sh or set ORCH_ENGINES_BIN." >&2
    return 1
}
if ! validate_composition "$PERSISTENCE" "$LAYOUT"; then
    exit 1
fi

# Resolve role: explicit --role wins; otherwise auto-detect from outfit/cut.
# Observer-class outfits/cuts are meta panes (spies, auditors) — they watch
# rather than do work, and bus subscribers filter them by metadata.role.
ROLE="$ROLE_OVERRIDE"
if [ -z "$ROLE" ]; then
    case "$OUTFIT" in
        stasi) ROLE=observer ;;
    esac
fi
if [ -z "$ROLE" ]; then
    case "$CUT" in
        wait-watch|spy-on-*) ROLE=observer ;;
    esac
fi
[ -z "$ROLE" ] && ROLE=worker

# CLASS derivation mirrors ROLE's outfit/cut conditions: stasi outfit or
# spy-on-* / wait-watch cut → observer, else active. Explicit --class wins.
# Reference: docs/proposals/2026-05-21-agent-role-registration.md (sesh repo).
if [ -n "$CLASS_OVERRIDE" ]; then
    CLASS="$CLASS_OVERRIDE"
elif [ "$ROLE" = "observer" ]; then
    CLASS="observer"
else
    CLASS="active"
fi

# Bridge resolution (Proposal 0010 / issue #182). Default per agent:
#   claude              → synadia-plugin (Phase A: nats-channel plugin
#                         bridges claude-code natively to the bus; no
#                         orch-agent-shim sidecar needed)
#   codex|pi|gemini|... → shim-adapter   (no Synadia plugin exists yet;
#                         Phase B's NATS↔ACP bridge replaces these)
#
# Explicit --bridge overrides the default. Codex/pi/gemini reject
# --bridge=synadia-plugin loudly — fail-loud preserves the operator's
# intent rather than silently downgrade them to a no-op shim launch.
# Likewise, --no-shim still suppresses any bus integration; bridge mode
# only controls WHICH bridge runs, not whether one runs at all.
if [ -z "$BRIDGE" ]; then
    case "$AGENT" in
        claude) BRIDGE=synadia-plugin ;;
        *)      BRIDGE=shim-adapter ;;
    esac
fi
if [ "$BRIDGE" = "synadia-plugin" ] && [ "$AGENT" != "claude" ]; then
    echo "orch-spawn: --bridge=synadia-plugin is currently only supported for agent=claude (got: $AGENT)" >&2
    echo "orch-spawn: codex/pi/gemini use --bridge=shim-adapter until Phase B's NATS↔ACP bridge lands" >&2
    exit 1
fi

# --worktree-from resolution: create a git worktree at <sha> under the
# worktree root and set that as the worker's cwd. Decoupled from --slug
# (the label) so callers can use either flag independently — see header
# comment for the matrix of combinations.
#
# Mutual exclusivity: --cwd and --sesh-session each pick their own
# checkout strategy; layering --worktree-from on top of either would
# stomp them silently. Refuse early with a helpful message.
#
# Slug synthesis when --worktree-from is set without --slug:
# `<sha7>-<rand4>` — short enough for a tmux pane title, unique enough
# under churn (4 random hex digits = 65k namespace per sha-prefix).
#
# Worktree root: ${ORCH_WORKTREE_ROOT} wins; otherwise we derive
# `${ORCH_PROJECTS_ROOT:-$HOME/projects}/<repo>-worktrees/<slug>` from
# the parent repo's basename. The parent repo is wherever orch-spawn is
# invoked from; if that's not a git repo we surface the error before
# touching the filesystem.
if [ $WORKTREE_FROM_FLAG -eq 1 ]; then
    if [ $CWD_FROM_FLAG -eq 1 ]; then
        echo "orch-spawn: --worktree-from and --cwd are mutually exclusive (got --worktree-from=$WORKTREE_FROM, --cwd=$CWD)" >&2
        exit 1
    fi
    if [ -n "$SESH_SESSION_FLAG" ]; then
        echo "orch-spawn: --worktree-from and --sesh-session are mutually exclusive (got --worktree-from=$WORKTREE_FROM, --sesh-session=$SESH_SESSION_FLAG)" >&2
        exit 1
    fi
    command -v git >/dev/null 2>&1 || { echo "orch-spawn: --worktree-from needs git on PATH" >&2; exit 1; }
    # Locate the parent repo. `git rev-parse --show-toplevel` is the
    # canonical way and reports the worktree's main checkout; that's
    # what we want for sibling-worktree placement.
    PARENT_REPO=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [ -z "$PARENT_REPO" ]; then
        echo "orch-spawn: --worktree-from needs to be run inside a git repository (cwd: $(pwd))" >&2
        exit 1
    fi
    # Verify the sha resolves to a commit. `git rev-parse --verify
    # <sha>^{commit}` returns 0 only for a real commit-ish; that's what
    # `git worktree add` needs. We probe here so the error attribution
    # is clear ("bad sha") instead of git-worktree's terser output.
    if ! WORKTREE_SHA_RESOLVED=$(git -C "$PARENT_REPO" rev-parse --verify "${WORKTREE_FROM}^{commit}" 2>/dev/null); then
        echo "orch-spawn: --worktree-from sha not found in repo at $PARENT_REPO: $WORKTREE_FROM" >&2
        exit 1
    fi
    # Synthesize a slug if none given. Bash $RANDOM is a 0..32767 int,
    # printf %04x prints up to 4 hex chars; the leading-zero pad keeps
    # the dir name stable-length.
    if [ $SLUG_FROM_FLAG -eq 0 ]; then
        SHA7=${WORKTREE_SHA_RESOLVED:0:7}
        printf -v RAND4 '%04x' "$(( RANDOM & 0xffff ))"
        SLUG="${SHA7}-${RAND4}"
        SLUG_FROM_FLAG=1
    fi
    REPO_BASENAME=$(basename "$PARENT_REPO")
    WORKTREE_ROOT="${ORCH_WORKTREE_ROOT:-${ORCH_PROJECTS_ROOT:-$HOME/projects}/${REPO_BASENAME}-worktrees}"
    WORKTREE_DIR="${WORKTREE_ROOT}/${SLUG}"
    if [ -e "$WORKTREE_DIR" ]; then
        echo "orch-spawn: --worktree-from target dir already exists: $WORKTREE_DIR (pick a different --slug or remove the dir)" >&2
        exit 1
    fi
    mkdir -p "$WORKTREE_ROOT"
    WT_STDERR=$(mktemp)
    if ! git -C "$PARENT_REPO" worktree add "$WORKTREE_DIR" "$WORKTREE_SHA_RESOLVED" 2>"$WT_STDERR" >/dev/null; then
        echo "orch-spawn: git worktree add failed: $(cat "$WT_STDERR")" >&2
        rm -f "$WT_STDERR"
        exit 1
    fi
    rm -f "$WT_STDERR"
    CWD=$WORKTREE_DIR
fi

# Slug-only validation (when --slug is set without --worktree-from). The
# slug shows up in a tmux pane title and in an alias-file key, so refuse
# values that would break either: shell metas, whitespace, slashes.
if [ -n "$SLUG" ]; then
    case "$SLUG" in
        *[!a-zA-Z0-9._-]*|"")
            echo "orch-spawn: --slug must match [a-zA-Z0-9._-]+ (got: $SLUG)" >&2
            exit 1
            ;;
    esac
fi

# Slug derivation when neither --slug, --instance-id, nor --worktree-from set
# one (Proposal 0009 / issue #181). The bus needs a stable identity per worker
# so subjects/aliases survive pane recycles; pct<pane-id> identity flips on
# every spawn. Preference order:
#   1. $SESH_SESSION from the parent shell (a sesh session label is already a
#      stable handle and matches the slug regex by convention).
#   2. None — emit a warning and fall through. The legacy pct-keyed track stays
#      live so the spawn still works; the operator gets a release to migrate.
# We re-run the slug regex against $SESH_SESSION because session labels can
# include characters outside [a-zA-Z0-9._-]; if it fails, we degrade to the
# "no slug" path rather than reject the spawn.
if [ -z "$SLUG" ] && [ -n "${SESH_SESSION:-}" ]; then
    case "$SESH_SESSION" in
        *[!a-zA-Z0-9._-]*|"") ;;
        *) SLUG=$SESH_SESSION; SLUG_FROM_FLAG=1 ;;
    esac
fi
if [ -z "$SLUG" ]; then
    echo "orch-spawn: no --instance-id / --slug given and \$SESH_SESSION is unset/invalid — falling back to pct-keyed identity. Migrate to stable slug identity per docs/migration/0009-instance-id.md before the next release deprecates pct-keyed subjects." >&2
fi

# --sesh-session resolution: ask sesh's worker-cwd helper for the fossil
# checkout dir. This is the worker-side leg of the fossil-as-trunk swarm
# workflow (sesh issue #64) — the worker lands inside a provisioned
# checkout under <project>/.sesh/checkouts/<label>/.
#
# Mutually exclusive with --cwd: passing both is operator confusion (the
# whole point of --sesh-session is "I don't know the checkout path,
# resolve it for me"). We check CWD_FROM_FLAG rather than [ -n "$CWD" ]
# because $CWD may have been seeded by a later --project resolution, and
# we want the conflict caught against the explicit flag, not against an
# implicit default.
#
# Resolution shells out to `sesh worker-cwd <label>`. Override the binary
# location via ORCH_SESH_BIN (default: `sesh` on PATH). The override path
# is mainly for tests — a CI build of sesh that hasn't been installed to
# PATH yet. On error we surface sesh's stderr verbatim so the operator
# sees the actual remediation hint (e.g. "run 'sesh worktree <label>'").
if [ -n "$SESH_SESSION_FLAG" ]; then
    if [ $CWD_FROM_FLAG -eq 1 ]; then
        echo "orch-spawn: --cwd and --sesh-session are mutually exclusive (got --cwd=$CWD, --sesh-session=$SESH_SESSION_FLAG)" >&2
        exit 1
    fi
    # Resolve ORCH_SESH_BIN to an absolute path BEFORE any cd. orch-spawn
    # later changes directory (via the executor's WRAP and via subshells
    # like `cd "$CWD" && pwd -P`); a relative ORCH_SESH_BIN would resolve
    # against whichever cwd happened to be active at call time, which is
    # confusing and brittle. `command -v` returns an absolute path when the
    # arg is a bare name on PATH; otherwise we accept the operator-supplied
    # path and require it to be executable.
    SESH_BIN_INPUT=${ORCH_SESH_BIN:-sesh}
    SESH_BIN=""
    case "$SESH_BIN_INPUT" in
        /*)
            # Already absolute — verify it's executable.
            [ -x "$SESH_BIN_INPUT" ] && SESH_BIN=$SESH_BIN_INPUT ;;
        */*)
            # Relative path with directory component — resolve against pwd
            # NOW (before any cd) and verify executable.
            _resolved=$(cd "$(dirname "$SESH_BIN_INPUT")" 2>/dev/null && pwd -P)/$(basename "$SESH_BIN_INPUT")
            [ -x "$_resolved" ] && SESH_BIN=$_resolved ;;
        *)
            # Bare name — look up on PATH. `command -v` returns the absolute
            # path for binaries it finds.
            SESH_BIN=$(command -v "$SESH_BIN_INPUT" 2>/dev/null || true) ;;
    esac
    if [ -z "$SESH_BIN" ] || [ ! -x "$SESH_BIN" ]; then
        echo "orch-spawn: --sesh-session needs the 'sesh' binary on PATH (or set ORCH_SESH_BIN=<absolute-path>) — got '$SESH_BIN_INPUT' — install from https://github.com/danmestas/sesh" >&2
        exit 1
    fi
    SESH_STDERR=$(mktemp)
    if SESH_CWD_RESOLVED=$("$SESH_BIN" worker-cwd "$SESH_SESSION_FLAG" 2>"$SESH_STDERR"); then
        :
    else
        SESH_RC=$?
        echo "orch-spawn: sesh worker-cwd $SESH_SESSION_FLAG failed (exit $SESH_RC): $(cat "$SESH_STDERR")" >&2
        rm -f "$SESH_STDERR"
        exit 1
    fi
    rm -f "$SESH_STDERR"
    # sesh prints exactly one line: the absolute checkout path. Trim any
    # trailing newline defensively.
    SESH_CWD_RESOLVED=$(printf '%s' "$SESH_CWD_RESOLVED" | tr -d '\n')
    if [ -z "$SESH_CWD_RESOLVED" ]; then
        echo "orch-spawn: sesh worker-cwd $SESH_SESSION_FLAG returned empty stdout" >&2
        exit 1
    fi
    CWD=$SESH_CWD_RESOLVED
fi

# Resolve --project to a directory:
#   1. zoxide query (if zoxide is installed and the name is indexed)
#   2. ~/projects/<name> (fallback for users without zoxide, or projects
#      not yet indexed in zoxide)
# Override the fallback root via ORCH_PROJECTS_ROOT (default: ~/projects).
if [ -n "$PROJECT" ] && [ -z "$CWD" ]; then
    if command -v zoxide >/dev/null 2>&1; then
        CWD=$(zoxide query "$PROJECT" 2>/dev/null || true)
    fi
    if [ -z "$CWD" ]; then
        FALLBACK="${ORCH_PROJECTS_ROOT:-$HOME/projects}/$PROJECT"
        if [ -d "$FALLBACK" ]; then
            CWD=$FALLBACK
        else
            echo "orch-spawn: cannot resolve --project $PROJECT — not in zoxide and not at $FALLBACK" >&2
            exit 1
        fi
    fi
fi
[ -z "$CWD" ] && CWD=$(pwd)

# Reject CWD values that would let a path craft shell injection into the
# spawned pane. The WRAP runs via /bin/sh -c with $CWD interpolated into
# `cd "$CWD"` and (for codex) a quoted -c argument. A path containing
# quotes, dollar-paren, backticks, or backslashes can break out of the
# quoting and execute arbitrary commands in the spawned shell. These
# characters are pathologically rare in real project paths; refuse early
# rather than ship an injection surface.
case "$CWD" in
    *[\"\'\$\\\`]*)
        echo "orch-spawn: unsafe characters in cwd ($CWD) — refusing to build a shell-injection-prone WRAP" >&2
        exit 1
        ;;
esac

# Auto-add the sesh-goal accessory when the operator is in an active goal
# pursuit. The accessory's hooks no-op when SESH_GOAL_ID isn't set, so the
# only cost of including it is a few extra files in the worker's bundle.
# Skip if --no-goal-accessory was passed, or if the operator already added
# it explicitly.
if [ -n "${SESH_GOAL_ID:-}" ] && [ -n "$OUTFIT" ] && [ $NO_GOAL_ACCESSORY -eq 0 ]; then
    HAVE_GOAL_ACC=0
    for a in "${ACCESSORIES[@]}"; do
        [ "$a" = "sesh-goal" ] && HAVE_GOAL_ACC=1
    done
    if [ $HAVE_GOAL_ACC -eq 0 ]; then
        ACCESSORIES+=("sesh-goal")
        echo "orch-spawn: SESH_GOAL_ID set in parent — auto-adding --accessory=sesh-goal (use --no-goal-accessory to opt out)" >&2
    fi
fi

# Outfit support: only claude has been verified end-to-end (test-suit-integration.sh).
# For other agents, suit's adapters emit different content per --target; wiring
# them up needs its own verification round.
BUNDLE=""
if [ -n "$OUTFIT" ]; then
    [ "$AGENT" = claude ] || { echo "orch-spawn: --outfit currently only supported for agent=claude (saw: $AGENT)" >&2; exit 1; }
    command -v suit >/dev/null 2>&1 || { echo "orch-spawn: suit not on PATH — install @agent-ops/suit" >&2; exit 1; }
    SUIT_CMD=(suit prepare --outfit "$OUTFIT" --target claude-code)
    [ -n "$CUT" ] && SUIT_CMD+=(--cut "$CUT")
    for a in "${ACCESSORIES[@]}"; do SUIT_CMD+=(--accessory "$a"); done
    # Prefer --quiet (suit v0.10+) for clean stdout=bundle-path; fall back to
    # legacy stdout-tail capture if suit doesn't recognize the flag.
    if BUNDLE=$("${SUIT_CMD[@]}" --quiet 2>/dev/null); then
        :
    elif LEGACY_OUT=$("${SUIT_CMD[@]}" 2>/dev/null); then
        BUNDLE=$(printf '%s\n' "$LEGACY_OUT" | tail -1)
    else
        BUNDLE=""
    fi
    [ -d "$BUNDLE" ] || { echo "orch-spawn: suit prepare failed (no bundle path returned)" >&2; exit 1; }
fi

# Build the env-export prefix for the worker's WRAP. ORCH_PANE_ID always.
# When the operator has an active goal pursuit, propagate the SESH_GOAL_*
# vars so the sesh-goal hooks activate in the worker's session.
#
# GOAL_EXPORTS is a shell fragment embedded into WRAP (the command string
# passed to `tmux split-window`). Values are inlined at build time (not
# referenced as \$VAR) because they must resolve in the parent's context,
# not the new pane's fresh env. We build the fragment via printf -v with
# %q so the values are shell-quoted by bash itself — robust against any
# shell metacharacters in the source vars, and shellcheck-clean (no
# SC2089/SC2090 because the quoting is delegated to printf).
GOAL_EXPORTS=""
goal_append() {
    local name=$1 value=$2 chunk
    printf -v chunk " export %s=%q;" "$name" "$value"
    GOAL_EXPORTS="${GOAL_EXPORTS}${chunk}"
}
if [ -n "${SESH_GOAL_ID:-}" ]; then
    goal_append SESH_GOAL_ID "$SESH_GOAL_ID"
    [ -n "${SESH_GOAL_SCOPE:-}" ]    && goal_append SESH_GOAL_SCOPE    "$SESH_GOAL_SCOPE"
    [ -n "${SESH_GOAL_SCOPE_ID:-}" ] && goal_append SESH_GOAL_SCOPE_ID "$SESH_GOAL_SCOPE_ID"
fi

# Slug-keyed env exports for the worker pane (Proposal 0009 / issue #181).
# Exports ORCH_INSTANCE_ID alongside the legacy ORCH_PANE_ID so workers can
# self-identify on the bus via a stable slug instead of a recyclable pane id.
# Empty when no slug source resolved (legacy pct-keyed identity path).
SLUG_EXPORTS=""
if [ -n "$SLUG" ]; then
    printf -v SLUG_EXPORTS " export ORCH_INSTANCE_ID=%q;" "$SLUG"
fi

# Locate the executor script relative to this binary. When orch-spawn is a
# symlink (e.g. ~/.local/bin/orch-spawn → /path/to/repo/bin/orch-spawn), we
# must resolve the symlink to find the repo root. readlink -f / realpath both
# work on Linux; on macOS use the pwd -P trick via a subshell.
_SELF="${BASH_SOURCE[0]}"
# Follow up to 5 levels of symlinks (avoids an infinite-loop on broken setups).
for _i in 1 2 3 4 5; do
    [ -L "$_SELF" ] || break
    _SELF=$(readlink "$_SELF")
    # Relative symlinks need resolving against the link's directory.
    case "$_SELF" in
        /*) ;;
        *) _SELF="$(dirname "${BASH_SOURCE[0]}")/$_SELF" ;;
    esac
done
ORCH_REPO_ROOT="$(cd "$(dirname "$_SELF")/.." && pwd -P)"

# resolve_executor — hybrid discovery for the executor backend command
# (Proposal 0003 / issue #142). Resolution precedence:
#   1. ${ORCH_EXECUTOR_<NAME>_CMD} — operator override. Value is treated as
#      a shell command string and invoked via `bash -c`, so it can be a
#      single binary path, a remote-invocation pipeline
#      (`curl -X POST https://my-cf-worker.dev`), or any other invocation
#      shape. Quoting/expansion happens inside the subshell, NOT in our
#      `eval`-free parent. Empty / unset env var skips this layer.
#   2. `command -v orch-executor-<name>` on PATH — for future native
#      binaries installed via npm/brew/goreleaser per the per-backend
#      release shape (Decision 8). PATH discovery only — no relative paths.
#   3. In-tree fallback: `${ORCH_REPO_ROOT}/executors/<name>/spawn.sh` —
#      preserves current behaviour during the gradual cutover (Decision 5).
#      The in-tree script must be executable.
#
# Name normalisation: <NAME> in the env var is the executor name uppercased
# with `-` → `_` (e.g., cf-worker → CF_WORKER). The PATH lookup and in-tree
# fallback use the literal name.
#
# Writes the resolved command string to stdout on success; exits non-zero
# with a diagnostic on stderr when no layer resolves.
resolve_executor() {
    local name=$1
    local env_name env_val path_bin tree_script
    env_name="ORCH_EXECUTOR_$(printf '%s' "$name" | tr 'a-z-' 'A-Z_')_CMD"
    env_val=${!env_name:-}
    if [ -n "$env_val" ]; then
        printf '%s' "$env_val"
        return 0
    fi
    path_bin=$(command -v "orch-executor-$name" 2>/dev/null || true)
    if [ -n "$path_bin" ]; then
        printf '%s' "$path_bin"
        return 0
    fi
    tree_script="${ORCH_REPO_ROOT}/executors/${name}/spawn.sh"
    if [ -x "$tree_script" ]; then
        printf 'bash %q' "$tree_script"
        return 0
    fi
    echo "orch-spawn: no executor backend resolved for '$name'. Tried:" >&2
    echo "  1. \$${env_name} (operator override) — unset or empty" >&2
    echo "  2. command -v orch-executor-${name} (PATH binary) — not found" >&2
    echo "  3. ${tree_script} (in-tree fallback) — missing or not executable" >&2
    echo "orch-spawn: install the backend (see docs/multi-executor-workers.md) or set ${env_name}=<command>" >&2
    return 1
}

EXECUTOR_CMD=$(resolve_executor "$EXECUTOR") || exit 1

# Delegate to the executor. All resolved state is exported so the executor
# can read it without re-parsing args. stdout from the executor is the pane
# id (or backend-equivalent handle); we capture it for the shim launch
# downstream.
#
# The resolved command is a shell-quoted string (in-tree fallback) or a
# bare path/command (PATH binary or env override). `bash -c` interprets
# it in a fresh subshell, so operator-supplied env overrides can carry
# pipelines, quoting, and $-expansions safely without us eval'ing in the
# parent. Exported vars (AGENT, CWD, …) propagate to the child shell.
#
# Issue #185: the executor emits the pane id on stdout BEFORE its --verify
# loop runs, so the pane id reaches us even when verify decides the agent
# failed to start. We deliberately capture the executor's exit code into
# SPAWN_RC (suppressing set -e via the `|| ...` form) and continue with the
# slug labeling + shim launch path; the shim's pane-watchdog handles the
# pane-died case cleanly, so launching it for an "unverified" pane is safe
# and is the correct behaviour when the pane is in fact alive. We re-honour
# the executor's exit code at the very end so callers still see rc=1 on
# verify failure.
SPAWN_RC=0
PANE=$(export AGENT CWD HEADLESS NO_FLEET POSITION VERIFY OUTFIT BUNDLE GOAL_EXPORTS SLUG_EXPORTS NO_SHIM ROLE BRIDGE; \
      bash -c "$EXECUTOR_CMD") || SPAWN_RC=$?

# Pre-pane failure (e.g., unknown AGENT before split-window, or split-window
# itself errored) — PANE is empty. No slug / shim work to do; just propagate
# the executor's exit code. Stdout stays empty in this case, preserving the
# pre-spawn error-path contract that test-orch-spawn-output.sh checks.
if [ -z "$PANE" ]; then
    exit "$SPAWN_RC"
fi

# Slug labeling (3 layers — operator-facing identity for the worker):
#   1. tmux pane title via `tmux select-pane -T <slug>`. Operators see this
#      in status bars and in the borders that surface `pane_title`.
#   2. ORCH_SLUG env var inside the pane (set via tmux send-keys against a
#      pre-prompt shell is unreliable; we publish it via setenv on the
#      session so subsequent panes spawned in the same window can read it).
#   3. Alias file (~/.config/orch-aliases, override via ORCH_ALIASES_FILE)
#      — appends `<slug>=<pane_id>` so orch-tell/orch-peek/orch-wait can
#      resolve the slug to a pane id without an active bus subscription.
#
# Run only when --slug is in effect; absent slug, none of these layers
# fire (preserves the legacy spawn shape).
if [ -n "$SLUG" ]; then
    # Layer 1 — pane title. Only meaningful for the tmux executor;
    # wasm/cf-worker doesn't have a tmux pane to label, and the executor
    # already mapped EXECUTOR=tmux as the only path that returns a
    # tmux-shaped pane id. We guard on the leading `%` for safety.
    case "$PANE" in
        %*)
            tmux select-pane -t "$PANE" -T "$SLUG" 2>/dev/null || true
            ;;
    esac
    # Layer 3 — alias file. Multiple spawns can race here; we use a
    # single-writer append via `flock` when available, falling back to a
    # best-effort append otherwise (the file is operator-managed and the
    # collision window is microseconds).
    #
    # Collision policy (Proposal 0009 / issue #181): if the slug is already
    # mapped to a DIFFERENT pane, refuse the spawn unless --force-slug was
    # passed. Re-mapping the same slug to the same pane (idempotent
    # re-spawn) is always allowed. Without this guard, two workers can
    # claim the same bus identity and the second silently steals the
    # first's subjects.
    ALIASES_FILE=${ORCH_ALIASES_FILE:-$HOME/.config/orch-aliases}
    mkdir -p "$(dirname "$ALIASES_FILE")"
    touch "$ALIASES_FILE"
    # Use -F (fixed-string) match with explicit "^...=" anchoring via awk
    # so a slug containing regex metachars (e.g. "a.b") can't accidentally
    # match a sibling line like "axb=%99". The slug regex permits "." and
    # "-" so the risk is real even though the namespace is tiny.
    EXISTING_PANE=$(awk -F= -v s="$SLUG" '$1==s {print $2; exit}' "$ALIASES_FILE" 2>/dev/null)
    if [ -n "$EXISTING_PANE" ] && [ "$EXISTING_PANE" != "$PANE" ] && [ $FORCE_SLUG -eq 0 ]; then
        echo "orch-spawn: slug '$SLUG' is already in use by $EXISTING_PANE (alias file: $ALIASES_FILE). Pass --force-slug to take over the alias (the previous worker keeps running but loses its name), or pick a different --instance-id." >&2
        # The pane has already been spawned by the executor; orch-down is
        # the cleanup primitive but we can't reliably invoke it from here
        # without leaking complexity. Surface the pane id so the operator
        # can clean up themselves; exit non-zero so callers don't treat
        # this as a successful spawn.
        echo "$PANE"
        exit 1
    fi
    if command -v flock >/dev/null 2>&1; then
        (
            flock -x 9
            # Strip any prior line for this slug so re-spawns don't
            # accumulate stale entries.
            if grep -qE "^${SLUG}=" "$ALIASES_FILE" 2>/dev/null; then
                grep -vE "^${SLUG}=" "$ALIASES_FILE" > "${ALIASES_FILE}.tmp" || true
                mv "${ALIASES_FILE}.tmp" "$ALIASES_FILE"
            fi
            printf '%s=%s\n' "$SLUG" "$PANE" >> "$ALIASES_FILE"
        ) 9>>"$ALIASES_FILE"
    else
        if grep -qE "^${SLUG}=" "$ALIASES_FILE" 2>/dev/null; then
            grep -vE "^${SLUG}=" "$ALIASES_FILE" > "${ALIASES_FILE}.tmp" || true
            mv "${ALIASES_FILE}.tmp" "$ALIASES_FILE"
        fi
        printf '%s=%s\n' "$SLUG" "$PANE" >> "$ALIASES_FILE"
    fi
fi

# Shim launch: start orch-agent-shim alongside the pane unless --no-shim.
# The shim registers the pane on the Synadia Agent Protocol bus so callers
# can discover it via $SRV.INFO.agents and prompt it over NATS.
#
# Env vars are exported explicitly into the background process rather than
# inherited implicitly — disown/nohup detach the process from the shell's
# job table but the env block is already resolved in the parent before the
# fork, so all seven vars (ORCH_OWNER, ORCH_OUTFIT, ORCH_ROLE, SESH_ROLE,
# SESH_CLASS, SESH_SESSION, NATS_URL) are correct in both bash and zsh.
# SESH_ROLE mirrors ORCH_ROLE for sesh-adapter consumers (Phase 2 of the
# agent role/class registration proposal); SESH_CLASS feeds the same
# adapter's coordination-subject routing.
#
# Adapter-less harnesses (codex/pi/gemini until Plans 11-13): orch-agent-shim
# exits 2 when invoked with an unknown adapter. We detect this by probing
# --agent before the real launch; if the exit is 2, we skip the shim and
# emit a warning (the legacy marker-hook fallback was retired in #94). Exit
# != 2 → try anyway; the shim surfaces real errors in its log (no point
# pre-empting an unclear failure).
#
# Stderr goes to ~/.cache/orch-shim/<pane_id>.log (pane id has %, use
# pct-form in path). Stdout is discarded (not part of spawn output contract).
#
# Bridge=synadia-plugin (claude only): skip the shim entirely — the
# Synadia nats-channel plugin runs inside claude and provides the bus
# bridge in-process. Launching the shim alongside would duplicate the
# bridge and race for the same subject. See Proposal 0010 / issue #182.
if [ "$BRIDGE" = "synadia-plugin" ]; then
    : # plugin runs inside claude; no sidecar shim
elif [ $NO_SHIM -eq 0 ]; then
    if command -v orch-agent-shim >/dev/null 2>&1; then
        # Translate agent name into the canonical Synadia identifier so
        # metadata.agent matches Appendix C. orch-spawn accepts "claude"
        # as the harness arg; Synadia knows it as "claude-code".
        case "$AGENT" in
            claude) SHIM_AGENT="claude-code" ;;
            *)      SHIM_AGENT="$AGENT" ;;
        esac

        # Probe: does this agent have a loaded adapter? orch-agent-shim --help
        # exits 0 for known adapters and 2 for unknown ones (adapter-not-found).
        # We use --help with an explicit --agent to trigger adapter selection
        # without actually running the shim.
        ADAPTER_EXIT=0
        if orch-agent-shim --agent "$SHIM_AGENT" --help >/dev/null 2>&1; then
            ADAPTER_OK=1
        else
            ADAPTER_EXIT=$?
            if [ "$ADAPTER_EXIT" -eq 2 ]; then
                ADAPTER_OK=0
            else
                ADAPTER_OK=1  # unexpected exit — try anyway; shim will surface error in log
            fi
        fi

        if [ $ADAPTER_OK -eq 1 ]; then
            # Resolve the five env vars that the shim needs. Inlined here
            # (not \$VAR references) so they resolve in the parent's context
            # and survive disown in both bash and zsh.
            SHIM_OWNER="${SESH_OWNER:-${USER:-$(id -un)}}"
            SHIM_SESSION="${SESH_SESSION:-}"
            SHIM_NATS="${NATS_URL:-}"

            # Log dir: use pct-form of pane id (% → pct) for safe filename.
            PANE_SAFE="${PANE//%/pct}"
            SHIM_LOG_DIR="$HOME/.cache/orch-shim"
            mkdir -p "$SHIM_LOG_DIR"
            SHIM_LOG="$SHIM_LOG_DIR/${PANE_SAFE}.log"

            # Build shim arg list. --instance-id is appended only when a
            # slug resolved (Proposal 0009 / issue #181); without it the
            # shim defaults to pct-keyed identity, preserving legacy
            # behaviour for the deprecation window.
            SHIM_ARGS=(
                --agent "$SHIM_AGENT"
                --pane "$PANE"
                --cwd "$CWD"
            )
            if [ -n "$SLUG" ]; then
                SHIM_ARGS+=(--instance-id "$SLUG")
            fi

            ORCH_OWNER="$SHIM_OWNER" \
            ORCH_OUTFIT="$OUTFIT" \
            ORCH_ROLE="$ROLE" \
            SESH_ROLE="$ROLE" \
            SESH_CLASS="$CLASS" \
            SESH_SESSION="$SHIM_SESSION" \
            NATS_URL="$SHIM_NATS" \
            orch-agent-shim "${SHIM_ARGS[@]}" \
                >"$SHIM_LOG" 2>&1 &
            disown
        else
            echo "orch-spawn: no shim adapter for $AGENT (adapter-less harness) — spawning without shim; bus integration is disabled for this pane" >&2
        fi
    else
        echo "orch-spawn: orch-agent-shim not on PATH — spawning without shim; install via install.sh to enable bus integration" >&2
    fi
fi

# Emit the pane id (always — issue #185). The executor exported it on
# stdout pre-verify so PANE is set even when --verify decided the agent
# wasn't ready; the pane is real and the shim is now bound, so the
# operator/caller needs the id to reach the worker even on the failure
# path. We re-honour the executor's exit code so callers still see rc=1
# when verify failed — preserving the failure signal — but stdout now
# always carries the pane id, matching the contract documented in
# executors/tmux/spawn.sh.
echo "$PANE"
exit "$SPAWN_RC"
