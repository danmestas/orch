#!/usr/bin/env bash
# orch-goal-stop-account-daemon — token accounting daemon for goal pursuits.
#
# Subscribes to per-harness Stop events and accumulates token spend into
# the active goal's budget tally. Launched by orch-goal-pursue.
#
# Resolution order:
#   1. vendor/orch-goal-stop-account-daemon (shipped by `npm install -g
#      @agent-ops/orch` via scripts/postinstall.js — fetched from the
#      matching GitHub Release).
#   2. .bin/orch-goal-stop-account-daemon (lazy-built from
#      cmd/orch-goal-stop-account-daemon on a dev checkout).
set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
pkg_root=$(cd "$script_dir/.." && pwd)

# 1. Prefer the vendored binary from the GH Release.
vendored="$pkg_root/vendor/orch-goal-stop-account-daemon"
if [ -x "$vendored" ]; then
    exec "$vendored" "$@"
fi

# 2. Fallback: dev-checkout lazy-build.
build_root="$script_dir"
while [ ! -f "$build_root/go.mod" ]; do
    parent=$(dirname "$build_root")
    if [ "$parent" = "$build_root" ]; then
        echo "orch-goal-stop-account-daemon: no vendored binary at $vendored and no go.mod above $script_dir" >&2
        echo "                                re-run \`npm install -g @agent-ops/orch\` (or unset ORCH_SKIP_DOWNLOAD if you set it)" >&2
        exit 1
    fi
    build_root="$parent"
done

src_dir="$build_root/cmd/orch-goal-stop-account-daemon"
build_dir="$build_root/.bin"
built="$build_dir/orch-goal-stop-account-daemon"

needs_build=0
if [ ! -x "$built" ]; then
    needs_build=1
else
    if find "$src_dir" "$build_root/internal" -name '*.go' -newer "$built" -print -quit 2>/dev/null | grep -q .; then
        needs_build=1
    fi
fi

if [ "$needs_build" -eq 1 ]; then
    if ! command -v go >/dev/null 2>&1; then
        echo "orch-goal-stop-account-daemon: no vendored binary and 'go' not on PATH; cannot build $src_dir" >&2
        exit 1
    fi
    mkdir -p "$build_dir"
    (cd "$build_root" && go build -o "$built" ./cmd/orch-goal-stop-account-daemon) \
        || { echo "orch-goal-stop-account-daemon: build failed" >&2; exit 1; }
fi

exec "$built" "$@"
