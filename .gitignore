# npm tarball + node_modules
*.tgz
node_modules/

# Scratch dir
tmp/

# OS / editor cruft
.DS_Store
*.swp
*~
.idea/
.vscode/

# Go build artifacts (orch-agent-shim is built via install.sh into ~/.local/bin)
/orch-agent-shim
/cmd/orch-agent-shim/orch-agent-shim
test/wire-compat/node_modules/
test/wire-compat/bun.lockb

# Extension binaries built lazily by orch-up
extensions/*/.bin/

# Lazy-built CLI binaries (bin/orch-workflow → cmd/orch-workflow)
/.bin/

# Vendored binaries fetched by scripts/postinstall.js for npm-installed
# users. Never committed; generated at install time.
/vendor/

# goreleaser build outputs. dist/schema/*.json is committed (spawnspec
# wire format reference) — keep that, ignore everything else goreleaser
# drops here.
/dist/orch_*
/dist/orch-*
/dist/artifacts.json
/dist/metadata.json
/dist/config.yaml
/dist/CHANGELOG.md
/dist/checksums.txt

# Go binaries accidentally built into the repo root by `go build ./cmd/<name>/`
# (the correct invocation is `go build -o .bin/<name> ./cmd/<name>`).
/orch-goal-stop-account-daemon
/orch-agent-shim
/orch-registry
/orch-workflow
/orch-engines
/orch-subtree
