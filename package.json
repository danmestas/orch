{
  "name": "@agent-ops/orch",
  "version": "0.1.0",
  "description": "Lightweight, extensible substrate for autonomous long-running multi-agent coordination on tmux.",
  "license": "Apache-2.0",
  "author": "Daniel Mestas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danmestas/orch.git"
  },
  "homepage": "https://github.com/danmestas/orch",
  "bugs": {
    "url": "https://github.com/danmestas/orch/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "orch-ask": "bin/orch-ask",
    "orch-claim-operator": "bin/orch-claim-operator",
    "orch-hide": "bin/orch-hide",
    "orch-listen": "bin/orch-listen",
    "orch-peek": "bin/orch-peek",
    "orch-register": "bin/orch-register",
    "orch-relayout": "bin/orch-relayout",
    "orch-setup": "bin/orch-setup",
    "orch-show": "bin/orch-show",
    "orch-spawn": "bin/orch-spawn",
    "orch-spy": "bin/orch-spy",
    "orch-subscribe": "bin/orch-subscribe",
    "orch-tell": "bin/orch-tell",
    "orch-version": "bin/orch-version",
    "orch-wait": "bin/orch-wait"
  },
  "files": [
    "bin/",
    "hooks/",
    "skills/",
